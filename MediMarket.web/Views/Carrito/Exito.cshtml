@{
    Layout = "~/Views/Shared/_LayoutShop.cshtml";
    ViewBag.Title = "Pedido Exitoso";
    
    // Rescatamos los datos que nos mandó el controlador
    string numeroOrden = TempData["NumeroOrden"]?.ToString();
    decimal totalPago = TempData["TotalPago"] != null ? (decimal)TempData["TotalPago"] : 0;
}

<div class="min-h-[80vh] flex items-center justify-center bg-gray-50 px-4">
    
    @* Tarjeta principal *@
    <div class="bg-white rounded-[2rem] shadow-2xl shadow-gray-200 w-full max-w-lg p-10 text-center">
        
        @* Ícono verde *@
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-check text-green-700 text-4xl"></i>
        </div>

        @* Textos principales *@
        <h1 class="text-4xl font-extrabold text-teal-800 mb-4 leading-tight">
            ¡Pedido realizado con<br>éxito!
        </h1>
        <p class="text-gray-600 text-sm mb-8 px-4 leading-relaxed">
            Hemos recibido tu solicitud y nuestro equipo clínico está procesando los artículos. Recibirás un correo electrónico de confirmación en breve.
        </p>

        @* Caja gris de resumen *@
        <div class="bg-gray-100 rounded-2xl p-6 flex justify-between items-center mb-8 text-left border-l-4 border-teal-700">
            <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Número de orden</p>
                <p class="font-bold text-gray-900">#@numeroOrden</p>
            </div>
            <div class="text-right">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Total a facturar</p>
                <p class="text-xl font-black text-teal-700">$@totalPago.ToString("N2")</p>
            </div>
        </div>

        @* Botones *@
        <div class="flex flex-col sm:flex-row gap-3">
            
            <a href="@Url.Action("MisPedidos", "Shop")" class="flex-1 bg-teal-800 hover:bg-teal-900 text-white font-bold py-3.5 px-4 rounded-xl transition-colors flex justify-center items-center gap-2 text-sm">
                <i class="fa-solid fa-receipt"></i> Ver mis pedidos
            </a>
            <a href="@Url.Action("Index", "Shop")" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3.5 px-4 rounded-xl transition-colors flex justify-center items-center gap-2 text-sm">
                <i class="fa-solid fa-store"></i> Volver al Marketplace
            </a>
        </div>

    </div>
</div>