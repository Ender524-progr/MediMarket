@using System.Security.Claims
@{
    var identity = (ClaimsIdentity)User.Identity;
    var nombre   = identity.FindFirst(ClaimTypes.Name)?.Value;
    var correo   = identity.FindFirst(ClaimTypes.Email)?.Value;
    var foto     = identity.FindFirst("foto_url")?.Value;
    var currentController = ViewContext.RequestContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RequestContext.RouteData.Values["action"]?.ToString();
    

    var dashboardActive = (currentController == "Proveedores" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var rfqsActive = (currentController == "Proveedores" && currentAction == "Cotizaciones")
        ? "bg-gray-400 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var catalogoActive = (currentController == "MiCatalogo" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var ordenesActive = (currentController == "Proveedores" && currentAction == "Ordenes")
        ? "bg-gray-400 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dashboard Proveedor</title>
    <!-- <link href="" rel="icon" type="image/png" /> -->
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
    <script src="~/Scripts/modernizr-2.6.2.js"></script>
</head>
<body class="bg-white min-h-screen">

    <aside
        id="Navbar"
        class="w-15 h-screen bg-gray-300 text-black p-2 fixed top-0 left-0 z-50
               transition-[width] duration-200 overflow-hidden">

        <!-- Logo -->
        <a href="@Url.Action("Index", "Home")"
           class="w-fit flex items-center gap-2 ml-2 mt-2 mb-6 rounded hover:text-green-700 text-xl font-semibold">
            <i class="fa-solid fa-briefcase-medical shrink-0 w-5 text-center"></i>
            <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                      transition-[max-width,opacity] duration-200">MediMarket</p>
        </a>

        <ul>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Proveedores")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @dashboardActive">
                    <i class="fas fa-tachometer-alt shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Dashboard</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Rfqs")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @rfqsActive">
                    <i class="fa-solid fa-quote-left shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Cotizaciones</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "MiCatalogo")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @catalogoActive">
                    <i class="fas fa-box shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Mi Catálogo</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Ordenes", "Proveedores")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @ordenesActive">
                    <i class="fas fa-shopping-cart shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Ordenes</p>
                </a>
            </li>
        </ul>
    </aside>

    <!-- El main usa margin-left en px para sincronizar con el aside -->
    <main id="MainContent"
          class="min-h-screen ml-15 transition-[margin-left] duration-200">
    <header class="sticky top-0 z-40 w-full h-16 bg-gray-200 flex items-center justify-between px-4 shadow">
    <div class="flex items-center gap-4 w-1/4">
        <input type="text" placeholder="Buscar..." class="px-3 py-1 rounded-md bg-gray-400/50 focus:outline-none focus:ring-2 focus:ring-green-600/50 w-full" />
    </div>
    <div class="flex items-center gap-4">
        <div class="relative">
            <button id="ToggleNotifications" class="text-gray-700 focus:outline-none cursor-pointer">
                <i class="fa-solid fa-bell"></i>
            </button>
            <span id="notifications"
           class="w-64 hidden absolute top-12 right-2 rounded-lg bg-gray-100 shadow-sm before:w-0 before:h-0 before:border-r-0 before:border-r-transparent before:border-l-24 before:border-l-transparent before:border-b-24 before:border-b-gray-100 before:-top-3 before:right-1  before:absolute">
           <div class="flex flex-col items-start w-full h-fit overflow-hidden ">
        <div class="w-full h-fit px-4 py-2 flex flex-col justify-center border-b border-b-gray-300">
            <h3>Notificaciones</h3>
            </div>
            <div class="flex flex-col items-center w-full h-fit overflow-hidden px-4 py-2">
                <p class="text-sm text-gray-500">No tienes nuevas notificaciones.</p>
            </div>
        </div>
            </span>
        </div>
        <div class="relative flex items-center gap-2">
            <button id="TogglePerfil" class="text-gray-700 focus:outline-none cursor-pointer">
            <img src="@ViewBag.FotoUrl" alt="Foto de perfil" class="w-8 h-8 rounded-full object-cover ring-2 ring-teal-400">
        </button>
        <span id="PerfilInfo"
    class="w-64 hidden absolute top-12 right-2 rounded-lg bg-gray-100 shadow-sm before:w-0 before:h-0 before:border-r-0 before:border-r-transparent before:border-l-24 before:border-l-transparent before:border-b-24 before:border-b-gray-100 before:-top-3 before:right-1  before:absolute">
    <div class="flex flex-col items-start w-full h-fit overflow-hidden ">
        <div class="w-full h-fit px-4 py-2 flex flex-col justify-center border-b border-b-gray-300">
            <h3>@nombre</h3>
            <small class="text-gray-500">@correo</small>
        </div>
        <a href="@Url.Action("Logout", "Account")" class="w-full h-fit px-4 py-2 block text-red-500 hover:text-red-700 hover:bg-red-300/50 rounded-b-lg">Cerrar sesión</a>
    </div>
  </span>
        </div>
    </div>
    
</header>

<script>
    // Toggle del perfil
    const perfilInfo = document.getElementById("PerfilInfo");
    document.getElementById("TogglePerfil").addEventListener("click", function(e) {
        e.stopPropagation();
        perfilInfo.classList.toggle("hidden");

        if (!perfilInfo.classList.contains("hidden")) {
            // Si se acaba de mostrar, ocultar las notificaciones
            const notifications = document.getElementById("notifications");
            if (!notifications.classList.contains("hidden")) {
                notifications.classList.add("hidden");
            }
        }
    });

    // Cerrar el perfil al hacer clic fuera de él
    document.addEventListener("click", function(event) {
        if(perfilInfo.classList.contains("hidden")) return; // Si ya está oculto, no hacer nada
        const isClickInside = perfilInfo.contains(event.target) || event.target.id === "TogglePerfil";
        if (!isClickInside) {
            perfilInfo.classList.add("hidden");
        }
    });

    // Toggle de notificaciones
    const notifications = document.getElementById("notifications");
    document.getElementById("ToggleNotifications").addEventListener("click", function(e) {
        e.stopPropagation();
        notifications.classList.toggle("hidden");

        if (!notifications.classList.contains("hidden")) {
            // Si se acaba de mostrar, ocultar el perfil
            const perfilInfo = document.getElementById("PerfilInfo");
            if (!perfilInfo.classList.contains("hidden")) {
                perfilInfo.classList.add("hidden");
            }
        }
    });

    // Cerrar las notificaciones al hacer clic fuera de ellas
    document.addEventListener("click", function(event) {
        if(notifications.classList.contains("hidden")) return; // Si ya está oculto, no hacer nada
        const isClickInside = notifications.contains(event.target) || event.target.id === "ToggleNotifications";
        if (!isClickInside) {
            notifications.classList.add("hidden");
        }
    });
</script>

        <section class=" w-full h-fit px-8">
            @RenderBody()
        </section>
    </main>

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script>
        const navbar = document.getElementById('Navbar');
        const mainContent = document.getElementById('MainContent');
        const txtNavbar = document.querySelectorAll('.txtNavbar');

        const COLLAPSED_W = '60px';
        const EXPANDED_W  = '220px';

        navbar.addEventListener('mouseenter', () => {
            navbar.style.width = EXPANDED_W;
            // mainContent.style.marginLeft = EXPANDED_W;//checar
            txtNavbar.forEach(txt => {
                txt.style.maxWidth = '160px';
                txt.style.opacity  = '1';
            });
        });

        navbar.addEventListener('mouseleave', () => {
            if (!navbar.classList.contains('fixed-open')) {
                navbar.style.width = COLLAPSED_W;
                // mainContent.style.marginLeft = COLLAPSED_W;//checar
                txtNavbar.forEach(txt => {
                    txt.style.maxWidth = '0';
                    txt.style.opacity  = '0';
                });
            }
        });
    </script>
</body>
</html>