@using System.Security.Claims
@{
    var identity = (ClaimsIdentity)User.Identity;
    var nombre   = identity.FindFirst(ClaimTypes.Name)?.Value;
    var correo   = identity.FindFirst(ClaimTypes.Email)?.Value;
    var foto     = identity.FindFirst("foto_url")?.Value;
    var currentController = ViewContext.RequestContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RequestContext.RouteData.Values["action"]?.ToString();


    var dashboardActive = (currentController == "Proveedores" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var rfqsActive = (currentController == "Rfqs" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var catalogoActive = (currentController == "MiCatalogo" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var ordenesActive = (currentController == "Ordenes" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";

    var analisisActive = (currentController == "Analisis" && currentAction == "Index")
        ? "bg-green-500/50 font-semibold border-r-4 border-green-600 hover:bg-green-600/50"
        : "hover:bg-gray-400";
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dashboard Proveedor</title>
    <!-- <link href="" rel="icon" type="image/png" /> -->
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
    <script src="~/Scripts/modernizr-2.6.2.js"></script>
</head>
<body class="bg-white min-h-screen">

    <aside
        id="Navbar"
        class="w-15 h-screen bg-gray-300 text-black p-2 fixed top-0 left-0 z-50
               transition-[width] duration-200 overflow-hidden">

        <!-- Logo -->
        <a href="@Url.Action("Index", "Home")"
           class="w-fit flex items-center gap-2 ml-2 mt-2 mb-6 rounded hover:text-green-700 text-xl font-semibold">
            <i class="fa-solid fa-briefcase-medical shrink-0 w-5 text-center"></i>
            <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                      transition-[max-width,opacity] duration-200">MediMarket</p>
        </a>

        <ul>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Proveedores")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @dashboardActive">
                    <i class="fas fa-tachometer-alt shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Resumen</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Rfqs")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @rfqsActive">
                    <i class="fa-solid fa-quote-left shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Cotizaciones</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "MiCatalogo")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @catalogoActive">
                    <i class="fas fa-box shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Mi Catálogo</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Ordenes")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @ordenesActive">
                    <i class="fas fa-shopping-cart shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Ordenes</p>
                </a>
            </li>
            <li class="mb-2">
                <a href="@Url.Action("Index", "Analisis")"
                   class="w-full flex items-center gap-2 py-2 px-3 rounded @analisisActive">
                    <i class="fas fa-chart-pie shrink-0 w-5 text-center"></i>
                    <p class="txtNavbar max-w-0 opacity-0 overflow-hidden whitespace-nowrap
                              transition-[max-width,opacity] duration-200">Análisis</p>
                </a>
            </li>
        </ul>
    </aside>

    <!-- El main usa margin-left en px para sincronizar con el aside -->
    <main id="MainContent"
          class="min-h-screen ml-15 transition-[margin-left] duration-200">
        <header class="sticky top-0 z-40 w-full h-16 bg-gray-200 flex items-center justify-between px-4 shadow">
            <!-- Buscador Global -->
            <form action="@Url.Action("BusquedaGlobal", "Proveedores")" method="GET" class="flex items-center gap-4 w-1/3 relative">
                <input type="text" name="q" placeholder="Buscar productos, órdenes..." required
                       class="px-3 py-1.5 rounded-md bg-white border border-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500 w-full text-sm text-gray-700 shadow-sm" />
                <button type="submit" class="absolute right-3 text-gray-400 hover:text-teal-600">
                    <i class="fas fa-search"></i>
                </button>
            </form>
            <div class="flex items-center gap-4">
                <!-- Dropdown Notificaciones -->
                <div class="relative flex items-center">
                    <button id="ToggleNotifications" class="text-gray-700 focus:outline-none cursor-pointer relative">
                        <i class="fa-solid fa-bell text-xl hover:text-teal-600 transition-colors"></i>

                        @* El globito rojo del contador *@
                        @if (ViewBag.TotalNotificaciones != null && ViewBag.TotalNotificaciones > 0)
                        {
                            <span class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center border-2 border-gray-200">
                                @ViewBag.TotalNotificaciones
                            </span>
                        }
                    </button>

                    <div id="notifications"
                         class="w-80 hidden absolute top-10 -right-2 rounded-xl bg-white shadow-xl border border-gray-200 before:w-0 before:h-0 before:border-r-0 before:border-r-transparent before:border-l-24 before:border-l-transparent before:border-b-24 before:border-b-white before:-top-3 before:right-4 before:absolute z-50">

                        @* ENVOLTORIO INTERNO CON ROUNDED (Para que no se salgan las esquinas cuadradas) *@
                        <div class="flex flex-col w-full h-fit overflow-hidden rounded-xl relative z-10 bg-white">

                            @* Cabecera del Modal (Cambiado a bg-white para que coincida con el triangulito) *@
                            <div class="w-full px-5 py-3 flex justify-between items-center border-b border-gray-100 bg-white">
                                <h3 class="font-bold text-gray-800 text-sm">Notificaciones</h3>
                            </div>

                            @* Lista de notificaciones *@
                            <div class="w-full max-h-72 overflow-y-auto divide-y divide-gray-50">
                                @if (ViewBag.Notificaciones != null && ((IEnumerable<MediMarket.web.Models.notificaciones_proveedores>)ViewBag.Notificaciones).Any())
                                {
                                    foreach (var noti in ViewBag.Notificaciones)
                                    {
                                        <div class="px-5 py-3 hover:bg-gray-50 transition cursor-pointer flex gap-3 group">
                                            @* Icono dinámico según el tipo *@
                                            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0
                                         @(noti.tipo == "rfq" ? "bg-blue-100 text-blue-600" :
                                           noti.tipo == "orden" ? "bg-emerald-100 text-emerald-600" :
                                           "bg-red-100 text-red-600")">
                                                <i class="fas @(noti.tipo == "rfq" ? "fa-file-invoice" : noti.tipo == "orden" ? "fa-box-open" : "fa-exclamation-triangle") text-xs"></i>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-gray-800 leading-tight mb-0.5 group-hover:text-teal-700 transition-colors">@noti.titulo</p>
                                                <p class="text-xs text-gray-500 leading-snug">@noti.mensaje</p>
                                                <p class="text-[10px] text-gray-400 mt-1 font-medium">@noti.creado_en.ToString("dd MMM, HH:mm")</p>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    @* Estado Vacío *@
                                    <div class="flex flex-col items-center justify-center py-8 px-4 text-center">
                                        <i class="fas fa-bell-slash text-3xl text-gray-200 mb-3"></i>
                                        <p class="text-sm font-bold text-gray-400">Todo al día</p>
                                        <p class="text-xs text-gray-400 mt-1">No tienes notificaciones nuevas por ahora.</p>
                                    </div>
                                }
                            </div>

                            @* Footer del Modal *@
                            <a href="#" class="w-full block text-center py-2.5 text-xs font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 border-t border-gray-100 transition">
                                Ver todo el historial
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Dropdown Perfil -->
                <div class="relative flex items-center gap-2">
                    <button id="TogglePerfil" class="text-gray-700 focus:outline-none cursor-pointer">
                        @* Nota: Cambié ViewBag.FotoUrl por la variable 'foto' que ya extraes de los claims arriba *@
                        <img src="@(foto ?? "/Content/img/default-user.png")" alt="Foto de perfil" class="w-8 h-8 rounded-full object-cover ring-2 ring-teal-400">
                    </button>

                    <div id="PerfilInfo"
                         class="w-72 hidden absolute top-12 right-0 rounded-xl bg-white shadow-lg border border-gray-100 before:w-0 before:h-0 before:border-r-0 before:border-r-transparent before:border-l-24 before:border-l-transparent before:border-b-24 before:border-b-white before:-top-3 before:right-2 before:absolute">

                        @* 1. Información del Usuario *@
                        <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
                            <img src="@(foto ?? "/Content/img/default-user.png")" class="w-10 h-10 rounded-full object-cover ring-2 ring-teal-100">
                            <div class="overflow-hidden">
                                <p class="font-bold text-gray-800 truncate leading-tight">@nombre</p>
                                <p class="text-xs text-gray-500 truncate">@correo</p>
                            </div>
                        </div>

                        @* 2. Información de la Empresa *@
                        <div class="px-5 py-3 bg-slate-50 border-b border-gray-100">
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Empresa actual</p>
                            @* Estos datos los pasaremos desde el controlador *@
                            <p class="font-bold text-teal-700 truncate text-sm">@(ViewBag.NombreEmpresa ?? "Mi Empresa")</p>
                            <p class="text-xs text-gray-500 truncate">RFC: @(ViewBag.RfcEmpresa ?? "Sin registrar")</p>
                        </div>

                        @* 3. Opciones / Enlaces rápidos *@
                        <div class="py-2 border-b border-gray-100">
                            <a href="@Url.Action("MiEmpresa", "Proveedores")" class="flex items-center gap-3 px-5 py-2 text-sm text-gray-600 hover:bg-teal-50 hover:text-teal-700 transition">
                                <i class="fas fa-building w-4 text-center"></i> Perfil de Empresa
                            </a>
                            <a href="@Url.Action("Configuracion", "Proveedores")" class="flex items-center gap-3 px-5 py-2 text-sm text-gray-600 hover:bg-teal-50 hover:text-teal-700 transition">
                                <i class="fas fa-cog w-4 text-center"></i> Configuración
                            </a>
                        </div>

                        @* 4. Cerrar sesión *@
                        <div class="py-2">
                            <a href="@Url.Action("Logout", "Account")" class="flex items-center gap-3 px-5 py-2 text-sm text-red-500 hover:bg-red-50 hover:text-red-700 transition font-medium">
                                <i class="fas fa-sign-out-alt w-4 text-center"></i> Cerrar sesión
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </header>

<script>
    // Toggle del perfil
    const perfilInfo = document.getElementById("PerfilInfo");
    document.getElementById("TogglePerfil").addEventListener("click", function(e) {
        e.stopPropagation();
        perfilInfo.classList.toggle("hidden");

        if (!perfilInfo.classList.contains("hidden")) {
            // Si se acaba de mostrar, ocultar las notificaciones
            const notifications = document.getElementById("notifications");
            if (!notifications.classList.contains("hidden")) {
                notifications.classList.add("hidden");
            }
        }
    });

    // Cerrar el perfil al hacer clic fuera de él
    document.addEventListener("click", function(event) {
        if(perfilInfo.classList.contains("hidden")) return; // Si ya está oculto, no hacer nada
        const isClickInside = perfilInfo.contains(event.target) || event.target.id === "TogglePerfil";
        if (!isClickInside) {
            perfilInfo.classList.add("hidden");
        }
    });

    // Toggle de notificaciones
    const notifications = document.getElementById("notifications");
    document.getElementById("ToggleNotifications").addEventListener("click", function(e) {
        e.stopPropagation();
        notifications.classList.toggle("hidden");

        if (!notifications.classList.contains("hidden")) {
            // Si se acaba de mostrar, ocultar el perfil
            const perfilInfo = document.getElementById("PerfilInfo");
            if (!perfilInfo.classList.contains("hidden")) {
                perfilInfo.classList.add("hidden");
            }
        }
    });

    // Cerrar las notificaciones al hacer clic fuera de ellas
    document.addEventListener("click", function(event) {
        if(notifications.classList.contains("hidden")) return; // Si ya está oculto, no hacer nada
        const isClickInside = notifications.contains(event.target) || event.target.id === "ToggleNotifications";
        if (!isClickInside) {
            notifications.classList.add("hidden");
        }
    });
</script>

        <section class=" w-full h-fit px-8">
            @RenderBody()
        </section>
    </main>

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script>
        const navbar = document.getElementById('Navbar');
        const mainContent = document.getElementById('MainContent');
        const txtNavbar = document.querySelectorAll('.txtNavbar');

        const COLLAPSED_W = '60px';
        const EXPANDED_W  = '220px';

        navbar.addEventListener('mouseenter', () => {
            navbar.style.width = EXPANDED_W;
            // mainContent.style.marginLeft = EXPANDED_W;//checar
            txtNavbar.forEach(txt => {
                txt.style.maxWidth = '160px';
                txt.style.opacity  = '1';
            });
        });

        navbar.addEventListener('mouseleave', () => {
            if (!navbar.classList.contains('fixed-open')) {
                navbar.style.width = COLLAPSED_W;
                // mainContent.style.marginLeft = COLLAPSED_W;//checar
                txtNavbar.forEach(txt => {
                    txt.style.maxWidth = '0';
                    txt.style.opacity  = '0';
                });
            }
        });
    </script>
</body>
</html>