<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediMarket</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
</head>
<body class="bg-white min-h-screen">

    @* ── Header fijo ──────────────────────────────────────────────────── *@
    <header class="w-full h-16 fixed top-0 left-0 right-0 flex items-center gap-4
                   bg-white border-b border-gray-100 shadow-sm z-50 px-4 md:px-8">

        @* Logo *@
        <a href="@Url.Action("Index", "Shop")"
           class="text-teal-700 text-xl font-black tracking-tight shrink-0 mr-2">
            Medi<span class="text-gray-800">Market</span>
        </a>

        @* Buscador — ocupa el espacio central *@
        @using (Html.BeginForm("Index", "Shop", FormMethod.Get, new { @class = "flex-1 max-w-2xl" }))
        {
            <div class="relative">
                <input type="text" name="q" value="@ViewBag.Busqueda"
                       placeholder="Buscar productos, suministros, equipos..."
                       class="w-full pl-10 pr-4 py-2 bg-gray-100 rounded-full text-sm
                              focus:outline-none focus:ring-2 focus:ring-teal-400 focus:bg-white transition" />
                <button type="submit"
                        class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 hover:text-teal-600">
                    <i class="fas fa-search text-sm"></i>
                </button>
            </div>
        }

        @* Navegación derecha *@
        <nav class="flex items-center gap-1 ml-auto shrink-0">
            <a href="@Url.Action("Index", "Shop")"
               class="hidden md:flex items-center gap-1.5 py-2 px-3 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                <i class="fas fa-store"></i>
                <span>Productos</span>
            </a>
            <a href="@Url.Action("Index", "Ordenes")"
               class="hidden md:flex items-center gap-1.5 py-2 px-3 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                <i class="fas fa-box"></i>
                <span>Mis pedidos</span>
            </a>

            @* Carrito *@
            <a href="@Url.Action("Index", "Carrito")"
               class="relative flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition text-gray-600">
                <i class="fas fa-shopping-cart"></i>
                @* Badge — conéctalo dinámicamente cuando tengas el carrito *@
                <span id="carritoCount"
                      class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-teal-600 text-white text-xs
                             font-bold rounded-full flex items-center justify-center hidden">0</span>
            </a>

            @* Notificaciones *@
            <button class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition text-gray-600">
                <i class="fas fa-bell"></i>
            </button>

            @* Menú de usuario *@
            <div class="relative" id="userMenuWrapper">
                <button id="userMenuBtn"
                        class="flex items-center gap-2 py-1.5 px-2 rounded-full hover:bg-gray-100 transition">
                    @{
                        var fotoUrl = ((System.Security.Claims.ClaimsIdentity)User.Identity)
                            .FindFirst("foto_url")?.Value;
                        var userName = User.Identity.Name;
                    }
                    @if (!string.IsNullOrWhiteSpace(fotoUrl))
                    {
                        <img src="@fotoUrl" alt="@userName"
                             class="w-8 h-8 rounded-full object-cover ring-2 ring-teal-400">
                    }
                    else
                    {
                        <div class="w-8 h-8 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm">
                            @(userName?.Substring(0, 1)?.ToUpper() ?? "U")
                        </div>
                    }
                    <i class="fas fa-chevron-down text-xs text-gray-400 hidden md:block"></i>
                </button>

                @* Dropdown *@
                <div id="userMenuDropdown"
                     class="hidden absolute right-0 top-full mt-2 w-52 bg-white border border-gray-100
                            rounded-xl shadow-lg z-50 overflow-hidden">
                    <div class="px-4 py-3 border-b border-gray-100">
                        <p class="text-sm font-semibold text-gray-800 truncate">@userName</p>
                        <p class="text-xs text-gray-400 truncate">
                            @((System.Security.Claims.ClaimsIdentity)User.Identity).FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                        </p>
                    </div>
                    <ul class="py-1">
                        <li>
                            <a href="@Url.Action("Index", "Proveedores")"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <i class="fas fa-tachometer-alt w-4 text-gray-400"></i> Mi Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Index", "MiCatalogo")"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                <i class="fas fa-box w-4 text-gray-400"></i> Mi Catálogo
                            </a>
                        </li>
                        <li class="border-t border-gray-100 mt-1">
                            <a href="@Url.Action("Logout", "Account")"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-red-500 hover:bg-red-50">
                                <i class="fas fa-sign-out-alt w-4"></i> Cerrar sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <script>
        // Toggle del menú de usuario
        const btn = document.getElementById('userMenuBtn');
        const dropdown = document.getElementById('userMenuDropdown');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', () => dropdown.classList.add('hidden'));
        dropdown.addEventListener('click', (e) => e.stopPropagation());
    </script>
</body>
</html>
