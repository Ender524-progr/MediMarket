<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediMarket</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
</head>
<body class="bg-white min-h-screen">

      @{
        var tipo = ((System.Security.Claims.ClaimsIdentity)User.Identity).FindFirst("tipo_usuario")?.Value;
        var carritoSesion = Session["Carrito"] as List<MediMarket.web.Controllers.CarritoController.CarritoItem>;
        int itemsEnCarrito = carritoSesion != null ? carritoSesion.Sum(i => i.Cantidad) : 0;
        
        var identity = (System.Security.Claims.ClaimsIdentity)User.Identity;
        var userEmail = identity.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "correo@no-encontrado.com";
        var fotoUrl = identity.FindFirst("foto_url")?.Value ?? identity.FindFirst("picture")?.Value ?? identity.FindFirst("urn:google:picture")?.Value;
        var userName = identity.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? identity.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity.Name ?? "Usuario";

        // NOTIFICACIONES GLOBALES
        var db = new MediMarket.web.Models.ConexionModel();
        var misNotificaciones = new List<MediMarket.web.Models.notificaciones_clinicas>();
        int totalSinLeer = 0;

        if (Request.IsAuthenticated)
        {
            var uidStr = identity.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(uidStr))
            {
                var uid = Guid.Parse(uidStr);
                var mClinica = db.clinicas.FirstOrDefault(c => c.usuario_id == uid);
                if (mClinica != null)
                {
                    // Traemos las últimas 10 notificaciones de esta clínica
                    misNotificaciones = db.notificaciones_clinicas
                                          .Where(n => n.clinica_id == mClinica.id)
                                          .OrderByDescending(n => n.creado_en)
                                          .Take(10)
                                          .ToList();
                    
                    totalSinLeer = misNotificaciones.Count(n => !n.leida);
                }
            }
        }
    }

    @* ── Header fijo ──────────────────────────────────────────────────── *@
    <header class="w-full h-16 fixed top-0 left-0 right-0 flex items-center gap-4
                   bg-white border-b border-gray-100 shadow-sm z-50                   
                    justify-between px-4 md:px-10 backdrop-blur-md
                   ">

        @* Logo *@
        <a href="@Url.Action("Index", "Shop")"
           class="text-teal-700 text-xl font-black tracking-tight shrink-0 mr-2">
            Medi<span class="text-gray-800">Market</span>
        </a>

        @* Buscador — ocupa el espacio central *@
        @using (Html.BeginForm("Index", "Shop", FormMethod.Get, new { @class = "flex-1 max-w-2xl" }))
        {
            <div class="relative">
                <input type="text" name="q" value="@ViewBag.Busqueda"
                       placeholder="Buscar productos, suministros, equipos..."
                       class="w-full pl-10 pr-4 py-2 bg-gray-100 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:bg-white transition" />
                
                <button type="submit" class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 hover:text-teal-600">
                    <i class="fas fa-search text-sm"></i>
                </button>
            </div>
        }

        @* Navegación derecha *@
        <nav class="flex items-center gap-1 ml-auto shrink-0">

            @if (tipo == "hibrido")
            {
                <a href="@Url.Action("Index", "Proveedores")" 
                   class="hidden md:flex items-center gap-1.5 py-2 px-3 rounded-lg text-sm 
                   text-gray-600 hover:bg-gray-200 transition-colors">
                    <i class="fa-solid fa-toolbox"></i>
                    <span>Mi dashboard</span>
                </a>
            }
            <a href="@Url.Action("MisPedidos", "Shop")"
               class="hidden md:flex items-center gap-1.5 py-2 px-3 rounded-lg text-sm 
               text-gray-600 hover:bg-gray-200 transition-colors">
                <i class="fas fa-box"></i>
                <span>Mis Pedidos</span>
            </a>

            @* Carrito *@
            <a href="@Url.Action("Index", "Carrito")"
               class="hidden md:flex items-center gap-1.5 py-2 px-3 rounded-lg text-sm 
               text-gray-600 hover:bg-gray-200 transition-colors relative">
                <i class="fas fa-shopping-cart"></i>
                <span>Mi Carrito</span>

                <span id="carritoCount"
                      class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-teal-600 text-white text-[10px] font-bold rounded-full items-center justify-center @(itemsEnCarrito > 0 ? "flex" : "hidden")">
                    @itemsEnCarrito
                </span>
            </a>

            @* Notificaciones *@
            <div class="relative flex items-center ml-2">
                <button id="ToggleNotifications" class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition text-gray-600 focus:outline-none relative">
                    <i class="fas fa-bell text-lg"></i>
                    @* Usamos la nueva variable totalSinLeer *@
                    @if (totalSinLeer > 0)
                    {
                        <span class="absolute top-1.5 right-1.5 bg-red-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center border-2 border-white">
                            @totalSinLeer
                        </span>
                    }
                </button>

                <div id="notificationsDropdown" class="hidden absolute top-12 -right-4 w-80 bg-white border border-gray-200 rounded-xl shadow-2xl z-50 overflow-hidden transform scale-95 opacity-0 transition-all duration-200 ease-out origin-top-right">
                    
                    @* Cabecera con botón de Marcar Todas *@
                    <div class="px-4 py-3 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
                        <h3 class="font-bold text-gray-800 text-sm">Notificaciones</h3>
                        @if (totalSinLeer > 0)
                        {
                            <button onclick="marcarTodasNotis()" class="text-[10px] font-bold text-teal-600 hover:text-teal-800 uppercase tracking-wider transition">
                                <i class="fas fa-check-double mr-1"></i> Marcar todas
                            </button>
                        }
                    </div>

                    <div class="max-h-72 overflow-y-auto divide-y divide-gray-50">
                        @if (misNotificaciones.Any())
                        {
                            foreach (var noti in misNotificaciones)
                            {
                                @* Le agregamos un ID y la clase group para el hover *@
                                <div id="noti_@noti.id" class="relative p-4 transition @(noti.leida ? "opacity-60 bg-white" : "bg-teal-50/40 hover:bg-teal-50") group">
                                    
                                    @* Botón minimalista de palomita (solo sale si no está leída) *@
                                    @if (!noti.leida)
                                    {
                                        <button onclick="marcarNotiLeida('@noti.id')" class="absolute top-4 right-4 text-gray-300 hover:text-teal-600 transition opacity-0 group-hover:opacity-100" title="Marcar como leída">
                                            <i class="fas fa-check-circle text-lg"></i>
                                        </button>
                                    }

                                    <p class="text-xs font-bold pr-6 @(noti.leida ? "text-gray-500" : "text-teal-800")">
                                        @noti.titulo
                                    </p>
                                    <p class="text-[11px] text-gray-500 mt-1 leading-tight pr-2">
                                        @noti.mensaje
                                    </p>
                                    <p class="text-[9px] text-gray-400 mt-2 font-medium">
                                        @noti.creado_en.ToString("dd MMM HH:mm")
                                    </p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="flex flex-col items-center justify-center py-8 px-4 text-center">
                                <i class="fas fa-bell-slash text-3xl text-gray-200 mb-3"></i>
                                <p class="text-sm font-bold text-gray-400">Todo al día</p>
                                <p class="text-xs text-gray-400 mt-1">No tienes alertas nuevas por ahora.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Menú de usuario *@
            <div class="relative" id="userMenuWrapper">
                <button id="userMenuBtn" class="flex items-center gap-2 py-1.5 px-2 rounded-full hover:bg-gray-100 transition focus:outline-none">
                    @{
  
                        if(string.IsNullOrWhiteSpace(userName)) { userName = "Usuario"; }

                        if (!string.IsNullOrWhiteSpace(fotoUrl) && !fotoUrl.StartsWith("http"))
                        {
                            fotoUrl = null;
                        }
                    }

                    @* Avatar  *@
                    <div class="relative w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-bold text-sm ring-2 ring-teal-400 overflow-hidden">
                        <span class="absolute z-0">@(userName.Substring(0, 1).ToUpper())</span>
                        @if (!string.IsNullOrWhiteSpace(fotoUrl))
                        {
                            <img src="@fotoUrl" alt="Perfil" referrerpolicy="no-referrer" class="absolute z-10 w-full h-full object-cover" onerror="this.style.display='none'" />
                        }
                    </div>
                </button>

                @* Dropdown*@
                <div id="userMenuDropdown" 
                     class="absolute right-0 top-full mt-2 w-72 
                     bg-white border border-gray-200 
                     rounded-xl shadow-2xl z-50 overflow-hidden 
                     transition-all duration-200 ease-out origin-top-right transform scale-95 opacity-0 invisible">
                    
                    @* 1. Información del Usuario (Diseño Josue adaptado a tus variables) *@
                    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
                        @* Tu avatar inteligente con inicial de respaldo *@
                        <div class="relative w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-bold text-sm ring-2 ring-teal-100 overflow-hidden shrink-0">
                            <span class="absolute z-0">@(userName.Substring(0, 1).ToUpper())</span>
                            @if (!string.IsNullOrWhiteSpace(fotoUrl))
                            {
                                <img src="@fotoUrl" referrerpolicy="no-referrer" class="absolute z-10 w-full h-full object-cover" onerror="this.style.display='none'" />
                            }
                        </div>
                        <div class="overflow-hidden">
                            <p class="font-bold text-gray-800 truncate leading-tight">@userName</p>
                            <p class="text-xs text-gray-500 truncate">@userEmail</p>
                        </div>
                    </div>
                    
                    @* 2. Información de la Clínica *@
                    <div class="px-5 py-3 bg-slate-50 border-b border-gray-100">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Clínica actual</p>
                        @* Cambié NombreEmpresa por NombreClinica para que tenga sentido en tu contexto *@
                        <p class="font-bold text-teal-700 truncate text-sm">@(ViewBag.NombreClinica ?? "Mi Clínica")</p>
                        <p class="text-xs text-gray-500 truncate">RFC: @(ViewBag.RfcClinica ?? "Sin registrar")</p>
                    </div>
                    
                    @* 3. Tus enlaces originales *@
                    <ul class="py-1">
                        <li>
                            <a href="@Url.Action("MiPerfil", "Clinica")" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:translate-x-1 hover:text-teal-600 transition-all">
                                <i class="fa-solid fa-house-medical w-4"></i> Mi Clínica
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Index", "ListaDeseos")" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:translate-x-1 hover:text-teal-600 transition-all">
                                <i class="fa-solid fa-heart w-4"></i> Lista de Deseos
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Index", "SolicitudesRfq")" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:translate-x-1 hover:text-teal-600 transition-all">
                                <i class="fa-solid fa-receipt w-4"></i> Mis Solicitudes
                            </a>
                        </li>
                        <li class="border-t border-gray-100 mt-1">
                            <a href="@Url.Action("Logout", "Account")" class="flex items-center gap-2 px-4 py-2 text-sm text-red-500 hover:translate-x-1 transition-all">
                                <i class="fas fa-sign-out-alt w-4"></i> Cerrar sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

@* --- BOTÓN FLOTANTE Y VENTANA DE CHAT DE POLA --- *@
<div id="polaChatContainer" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
    
    @* Ventana del Chat (Oculta por defecto) *@
    <div id="polaChatWindow" class="hidden mb-4 w-[350px] sm:w-[340px] h-[600px] rounded-2xl shadow-2xl flex flex-col overflow-hidden border border-white/40 bg-white/70 backdrop-blur-lg transition-all duration-300 origin-bottom-right scale-95 opacity-0">
        
        @* Header Verde (Sin blur para que resalte) *@
        <div class="bg-transparent px-5 py-4 flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-white/60 flex items-center justify-center text-gray-600 font-bold">
                    <i class="fa-solid fa-user-nurse"></i>
                </div>
                <div>
                    <h3 class="text-gray-600 font-bold text-base leading-tight">Beimark</h3>
                    <p class="text-teal-600 text-xs flex items-center gap-1">
                        <span class="w-2 h-2 rounded-full bg-teal-600"></span> En línea
                    </p>
                </div>
            </div>
            <button id="closePolaBtn" class="text-gray-600 hover:text-teal-600 transition">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>

        @* Área de Mensajes *@
        <div id="polaChatMessages" class="flex-1 overflow-y-auto p-5 space-y-4 bg-transparent scroll-smooth">
            @* Mensaje de bienvenida de Pola *@
            <div class="flex items-end gap-2 w-full">
                <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center text-gray-600 text-xs shrink-0">
                    <i class="fa-solid fa-user-nurse"></i>
                </div>
                <div class="bg-white/80 border border-gray-200 text-gray-700 text-xs py-2 px-4 rounded-2xl rounded-bl-none shadow-md max-w-[85%]">
                    Hola, soy Beimark, tu asistente clínico personal. Fui alertado de una necesidad de suministros en tu clínica. ¿En qué te puedo asesorar hoy? 🫣
                </div>
            </div>
        </div>

        @* Escribiendo... (Oculto por defecto) *@
        <div id="polaTyping" class="hidden px-5 py-2 text-xs text-gray-400 font-medium italic bg-transparent">
            Beimark está escribiendo...
        </div>

        @* Área de Input (Fondo sólido para que se vea claro lo que escribes) *@
        <div class="p-3 bg-white border-t border-gray-100 shrink-0">
            <div class="relative flex items-center">
                <input type="text" id="polaInput" autocomplete="off" placeholder="Escribe tu mensaje..." 
                       class="w-full bg-gray-50 text-sm text-gray-800 rounded-full pl-4 pr-12 py-2 focus:outline-none focus:ring-1 focus:ring-teal-700/50 border border-transparent transition" />
                <button id="polaSendBtn" class="absolute right-2 w-8 h-8 rounded-full bg-teal-700 text-white flex items-center justify-center hover:bg-teal-800 transition">
                    <i class="fa-solid fa-paper-plane text-xs -ml-0.5 mt-0.5"></i>
                </button>
            </div>
        </div>
    </div>

    @* Botón Flotante (FAB) *@
    <button id="polaFabBtn" class="w-12 h-12 rounded-full bg-teal-700 text-white shadow-xl hover:bg-teal-800 hover:scale-105 transition-all flex items-center justify-center group focus:outline-none">
        <i class="fa-regular fa-comments text-xl hidden group-hover:block transition-all"></i>
    </button>
</div>

    <script>
        // Toggle del menú de usuario
        const btn = document.getElementById('userMenuBtn');
        const dropdown = document.getElementById('userMenuDropdown');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('invisible');
            dropdown.classList.toggle('opacity-0');
            dropdown.classList.toggle('scale-95');
            dropdown.classList.toggle('opacity-100');
            dropdown.classList.toggle('scale-100');
        });

        // Cerrar al hacer clic afuera
        document.addEventListener('click', () => {
            dropdown.classList.add('invisible', 'opacity-0', 'scale-95');
            dropdown.classList.remove('opacity-100', 'scale-100');
        });
        
        dropdown.addEventListener('click', (e) => e.stopPropagation());
  
        // Función global para actualizar el numerito del carrito 
        function actualizarContadorCarrito(cantidad) {
            const badge = document.getElementById('carritoCount');
            if (badge) {
                badge.textContent = cantidad;
                if (cantidad > 0) {
                    badge.classList.remove('hidden');
                    badge.classList.add('flex');
                } else {
                    badge.classList.add('hidden');
                    badge.classList.remove('flex');
                }
            }
        }

    function agregarAlCarrito(productoId) {
        // Usamos fetch para enviar los datos al controlador CarritoController
        fetch('/Carrito/Agregar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productoId: productoId, cantidad: 1 })
        })
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                // Si todo salió bien, mostramos el aviso y actualizamos el numerito rojo
                mostrarToast('Producto agregado al carrito', 'success');
                actualizarContadorCarrito(data.contador); 
            } else {
                mostrarToast(data.mensaje || 'Error al agregar', 'error');
            }
        })
        .catch(() => mostrarToast('No se pudo conectar con el servidor', 'error'));
    }

    function mostrarToast(msg, tipo) {
        const toast = document.createElement('div');
        toast.className = `fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl shadow-lg text-white text-sm font-semibold transition-all
            ${tipo === 'success' ? 'bg-teal-600' : tipo === 'info' ? 'bg-gray-600' : 'bg-red-500'} `;
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

     // Lógica del Chat de Pola
document.addEventListener('DOMContentLoaded', () => {
    const fabBtn = document.getElementById('polaFabBtn');
    const closeBtn = document.getElementById('closePolaBtn');
    const chatWindow = document.getElementById('polaChatWindow');
    const chatMessages = document.getElementById('polaChatMessages');
    const chatInput = document.getElementById('polaInput');
    const sendBtn = document.getElementById('polaSendBtn');
    const typingIndicator = document.getElementById('polaTyping');

    // Abrir/Cerrar chat con animación
    const toggleChat = () => {
        chatWindow.classList.toggle('hidden');
        setTimeout(() => {
            chatWindow.classList.toggle('scale-95');
            chatWindow.classList.toggle('opacity-0');
        }, 10);
        if(!chatWindow.classList.contains('hidden')) chatInput.focus();
    };

    fabBtn.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    // Función para pintar burbujitas en el HTML
    const addMessage = (text, isUser) => {
        const msgDiv = document.createElement('div');
        msgDiv.className = `flex items-end gap-2 w-full ${isUser ? 'justify-end' : ''} mb-4`;
        
        let avatarHTML = isUser ? '' : `
            <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center text-gray-700 text-xs shrink-0">
                <i class="fa-solid fa-user-nurse"></i>
            </div>
        `;

        let bubbleHTML = `
            <div class="text-xs py-2 px-4 shadow-md max-w-[85%] 
                ${isUser ? 'bg-gray-300 text-gray-700 rounded-2xl rounded-br-none' 
                         : 'bg-white/80 border border-gray-200 text-gray-700 rounded-2xl rounded-bl-none'}">
                ${text.replace(/\n/g, '<br>')}
            </div>
        `;

        msgDiv.innerHTML = isUser ? bubbleHTML : avatarHTML + bubbleHTML;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight; // Auto-scroll pa' abajo
    };

    // Enviar mensaje al backend
    const sendMessage = () => {
        const text = chatInput.value.trim();
        if (!text) return;

        // 1. Mostrar mensaje del usuario
        addMessage(text, true);
        chatInput.value = '';
        
        // 2. Mostrar "Escribiendo..."
        typingIndicator.classList.remove('hidden');
        chatMessages.scrollTop = chatMessages.scrollHeight;

        // 3. Petición a tu controlador C#
        fetch('/Chat/EnviarMensaje', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mensajeUsuario: text })
        })
        .then(r => r.json())
        .then(data => {
            typingIndicator.classList.add('hidden');
            if (data.ok) {
                addMessage(data.respuesta, false);
            } else {
                addMessage("Ups, me desconecté un segundo. ¿Me lo repites? 🥺", false);
                console.error(data.respuesta);
            }
        })
        .catch(() => {
            typingIndicator.classList.add('hidden');
            addMessage("Parece que mi servidor está durmiendo. 💤 Intenta en un momento.", false);
        });
    };

    // Eventos para enviar (Clic y Enter)
    sendBtn.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
    });
});

// Toggle del menú de Notificaciones
        const notiBtn = document.getElementById('ToggleNotifications');
        const notiDropdown = document.getElementById('notificationsDropdown');

        notiBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            notiDropdown.classList.toggle('hidden');
            setTimeout(() => {
                notiDropdown.classList.toggle('opacity-0');
                notiDropdown.classList.toggle('scale-95');
            }, 10);
            
            // Si abro notificaciones, cierro el menú de usuario
            dropdown.classList.add('invisible', 'opacity-0', 'scale-95');
            dropdown.classList.remove('opacity-100', 'scale-100');
        });

        document.addEventListener('click', () => {
            notiDropdown.classList.add('opacity-0', 'scale-95');
            setTimeout(() => notiDropdown.classList.add('hidden'), 200);
        });

        notiDropdown.addEventListener('click', (e) => e.stopPropagation());

        btn.addEventListener('click', (e) => {
            notiDropdown.classList.add('opacity-0', 'scale-95');
            setTimeout(() => notiDropdown.classList.add('hidden'), 200);
        });

        function marcarNotiLeida(id) {
        fetch(`/Notificaciones/MarcarLeida?id=${id}`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if(data.ok) {
                const div = document.getElementById('noti_' + id);
                div.classList.remove('bg-teal-50/40', 'hover:bg-teal-50');
                div.classList.add('opacity-60', 'bg-white');
                
                const btn = div.querySelector('button');
                if(btn) btn.remove();

                const titulo = div.querySelector('p.font-bold');
                titulo.classList.remove('text-teal-800');
                titulo.classList.add('text-gray-500');

                location.reload(); 
            }
        });
    }

    function marcarTodasNotis() {
        fetch(`/Notificaciones/MarcarTodas`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if(data.ok) {
                location.reload();
            }
        });
    }
    </script>
</body>
</html>
