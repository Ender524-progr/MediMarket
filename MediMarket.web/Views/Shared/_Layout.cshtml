<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediMarket</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css"/>
     <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
</head>
<body class="bg-white min-h-screen">
    <header class="w-full h-16 fixed flex justify-between items-center text-black px-4 md:px-10 bg-white backdrop-blur-md z-10">
        <div>
            @Html.ActionLink("MediMarket", "Index", "Home", null, null, "INICIO", null, new { @class = "flex items-center gap-4 text-teal-700 text-2xl font-bold" })            
        </div>
        <nav id="mainNav" class="w-full md:w-fit hidden md:flex absolute left-0 md:relative mt-16 md:mt-0 md:gap-6">
            <div class="not-md:bg-linear-to-b from-white to-teal-100 rounded-b-xl md:bg-white flex gap-10 flex-col md:flex-row items-center w-full md:w-auto px-4 py-6 md:p-0 absolute md:relative left-0 top-full">
                @Html.ActionLink("CARACTERÍSTICAS", "Index", "Home", null, null, "CARACTERiSTICAS", null, new { @class = "text-gray-700 font-medium hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                @Html.ActionLink("CÓMO FUNCIONA", "Index", "Home", null, null, "FUNCION", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                @Html.ActionLink("PRECIOS", "Index", "Home", null, null, "PRECIOS", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
            </div>
                </nav>
                @* --- Lógica de Autenticación en el Navbar --- *@
@if (Request.IsAuthenticated)
{
    <div class="flex items-center gap-4">
        
        @* 1. NUEVO BOTÓN DEL MARKETPLACE (Solo visible con sesión) *@
        <a href="@Url.Action("Index", "Shop")" 
           class="flex items-center gap-2 text-teal-700 bg-teal-50 hover:translate-y-0.5 hover:border-teal-200 transition-all px-4 py-2 rounded-full font-semibold text-sm border border-teal-100 shadow-sm">
            <i class="fa-solid fa-store"></i>
            <span class="hidden sm:inline">Tienda</span>
        </a>

    <div class="relative" id="userMenuWrapper">
        <button id="userMenuBtn" class="flex items-center gap-2 py-1.5 px-2 rounded-full hover:bg-gray-100 transition">
            @{
                // 1. Extraemos la identidad una sola vez para no repetir código
                var identity = (System.Security.Claims.ClaimsIdentity)User.Identity;

                // 2. Buscamos el nombre real (Google lo suele guardar en 'Name' o 'GivenName')
                var userName = identity.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value 
                               ?? identity.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value 
                               ?? User.Identity.Name 
                               ?? "Usuario";

                // 3. Buscamos el correo de forma limpia
                var userEmail = identity.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value 
                                ?? "correo@no-encontrado.com";

                // 4. Buscamos la foto en los posibles nombres que usa Google o tu BD
                var fotoUrl = identity.FindFirst("foto_url")?.Value 
                              ?? identity.FindFirst("picture")?.Value 
                              ?? identity.FindFirst("urn:google:picture")?.Value;

                // Si la URL no empieza con http, la anulamos para que muestre la inicial
                if (!string.IsNullOrWhiteSpace(fotoUrl) && !fotoUrl.StartsWith("http"))
                {
                    fotoUrl = null;
                }
            }

            @* Renderizado de la Foto (con escudo anti-errores) *@
            <div class="relative w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-bold text-sm ring-2 ring-teal-400 overflow-hidden">
                
                @* 1. La inicial siempre está viva al fondo *@
                <span class="absolute z-0">@(userName.Substring(0, 1).ToUpper())</span>

                @* 2. La foto intenta cargarse por encima *@
                @if (!string.IsNullOrWhiteSpace(fotoUrl))
                {
                    <img src="@fotoUrl" 
                         alt="Perfil" 
                         referrerpolicy="no-referrer"
                         class="absolute z-10 w-full h-full object-cover"
                         onerror="this.style.display='none'" />
                }
            </div>
            <i class="fas fa-chevron-down text-xs text-gray-400 hidden md:block"></i>
        </button>

        @* Dropdown Menu *@
        <div id="userMenuDropdown" class="hidden absolute right-0 top-full mt-2 w-52 bg-white border border-teal-200 rounded-xl shadow-2xl z-50 overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-100">
                @* Aquí solo imprimimos las variables limpias *@
                <p class="text-sm font-semibold text-gray-800 truncate">@userName</p>
                <p class="text-xs text-gray-400 truncate">@userEmail</p>
            </div>
            <ul class="py-1">
                <li>
                    <a href="@Url.Action("Index", "Proveedores")" class="
                    flex items-center 
                    gap-2 px-4 py-2 
                    text-sm text-gray-700 
                    hover:translate-x-1 transition-transform">
                        <i class="fas fa-tachometer-alt w-4 text-gray-400"></i> Mi Dashboard
                    </a>
                </li>
                <li class="border-t border-gray-100 mt-1">
                    <a href="@Url.Action("Logout", "Account")" class="
                    flex items-center 
                    gap-2 px-4 py-2 
                    text-sm text-red-500 
                    hover:translate-x-1 transition-transform">
                        <i class="fas fa-sign-out-alt w-4"></i> Cerrar sesión
                    </a>
                </li>
            </ul>
        </div>
    </div>
    </div>
}
else
{
    <a href="@Url.Action("Login", "Account")" class="px-6 py-2.5 bg-teal-700 hover:bg-teal-800 text-white text-sm font-bold rounded-full transition-colors shadow-md">
        COMENZAR
    </a>
}

        <button id="bars" class="md:hidden text-teal-700 focus:outline-none">
            <i class="fa-solid fa-bars"></i>
        </button>
    </header>
    @RenderBody()
    <footer class="w-full h-fit px-4 md:px-14 py-8 bg-white mt-16">
        <div class="w-full md:flex justify-between">
            <section class="md:w-2/5">
                <h2 class="flex items-center gap-2 text-teal-700 font-bold text-2xl">MediMarket</h2>
                <p class="text-gray-700 hidden md:flex">Digitalizando el suministro médico para un sistema de salud más eficiente y transparente a través de tecnología B2B</p>
            </section>
                <nav class="md:w-3/5 flex justify-end items-end">
                    <div class="flex flex-col md:flex-row text-right md:gap-6">
                    @Html.ActionLink("CARACTERÍSTICAS", "Index", "Home", null, null, "CARACTERiSTICAS", null, new { @class = "text-gray-700 font-medium hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    @Html.ActionLink("CÓMO FUNCIONA", "Index", "Home", null, null, "FUNCION", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    @Html.ActionLink("PRECIOS", "Index", "Home", null, null, "PRECIOS", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    </div>
                </nav>
        </div>
        <hr class="my-6 border-gray-800" />
        <div>
            <p class="text-center text-gray-700">&copy; @DateTime.Now.Year MediMarket. Todos los derechos reservados.</p>
        </div>
    </footer>   
    <script>
        const bars = document.getElementById('bars');
        const mainNav = document.getElementById('mainNav');
        // Toggle del menú al hacer clic en el ícono de barras
        bars.addEventListener('click', () => {
            mainNav.classList.toggle('hidden');
        });
        // Cerrar el menú al hacer clic en un otra parte de la página
        document.addEventListener('click', (event) => {
            if (!mainNav.contains(event.target) && !bars.contains(event.target)) {
                mainNav.classList.add('hidden');
            }
        });

        // Script para abrir/cerrar el dropdown del usuario en el Navbar
    const userMenuBtn = document.getElementById('userMenuBtn');
    const userMenuDropdown = document.getElementById('userMenuDropdown');

    if (userMenuBtn && userMenuDropdown) {
        userMenuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            userMenuDropdown.classList.toggle('hidden');
        });

        // Cerrar si se hace clic afuera
        document.addEventListener('click', (e) => {
            if (!userMenuBtn.contains(e.target) && !userMenuDropdown.contains(e.target)) {
                userMenuDropdown.classList.add('hidden');
            }
        });
    }
    </script>
</body>
</html>
