<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediMarket</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css"/>
     <link rel="stylesheet" href="~/Content/fontawesome/css/all.min.css" />
</head>
<body class="bg-white min-h-screen">
    <header class="w-full h-16 fixed flex justify-between items-center text-black px-4 md:px-10 bg-white backdrop-blur-md z-10">
        <div>
            @Html.ActionLink("MediMarket", "Index", "Home", null, null, "INICIO", null, new { @class = "flex items-center gap-4 text-teal-700 text-2xl font-bold" })            
        </div>
        <nav id="mainNav" class="w-full md:w-fit hidden md:flex absolute left-0 md:relative mt-16 md:mt-0 md:gap-6">
            <div class="not-md:bg-linear-to-b from-white to-teal-100 rounded-b-xl md:bg-white flex gap-10 flex-col md:flex-row items-center w-full md:w-auto px-4 py-6 md:p-0 absolute md:relative left-0 top-full">
                @Html.ActionLink("CARACTERÍSTICAS", "Index", "Home", null, null, "CARACTERiSTICAS", null, new { @class = "text-gray-700 font-medium hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                @Html.ActionLink("CÓMO FUNCIONA", "Index", "Home", null, null, "FUNCION", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                @Html.ActionLink("PRECIOS", "Index", "Home", null, null, "PRECIOS", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
            </div>
                </nav>
                @* --- Lógica de Autenticación en el Navbar --- *@
@if (Request.IsAuthenticated)
{
    // Tipo de usuario (Hibrido, Comprador, Proveedor)
    var tipo = ((System.Security.Claims.ClaimsIdentity)User.Identity).FindFirst("tipo_usuario")?.Value;

    <div class="flex items-center gap-4">
        
        @if (tipo == "clinica" || tipo == "hibrido")
        {
        @* NUEVO BOTÓN DEL MARKETPLACE *@
        <a href="@Url.Action("Index", "Shop")" 
           class="flex items-center gap-2 text-teal-700 bg-teal-50 hover:translate-y-0.5 hover:border-teal-200 transition-all px-4 py-2 rounded-full font-semibold text-sm border border-teal-100 shadow-sm">
            <i class="fa-solid fa-store"></i>
            <span class="hidden sm:inline">Tienda</span>
        </a>
        }

    <div class="relative" id="userMenuWrapper">
        <button id="userMenuBtn" class="flex items-center gap-2 py-1.5 px-2 rounded-full hover:bg-gray-100 transition">
            @{       

                // 1. Extraemos la identidad una sola vez para no repetir código
                var identity = (System.Security.Claims.ClaimsIdentity)User.Identity;

                // 2. Buscamos el nombre real (Google lo suele guardar en 'Name' o 'GivenName')
                var userName = identity.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value 
                               ?? identity.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value 
                               ?? User.Identity.Name 
                               ?? "Usuario";

                // 3. Buscamos el correo de forma limpia
                var userEmail = identity.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value 
                                ?? "correo@no-encontrado.com";

                // 4. Buscamos la foto en los posibles nombres que usa Google o tu BD
                var fotoUrl = identity.FindFirst("foto_url")?.Value 
                              ?? identity.FindFirst("picture")?.Value 
                              ?? identity.FindFirst("urn:google:picture")?.Value;

                // Si la URL no empieza con http, la anulamos para que muestre la inicial
                if (!string.IsNullOrWhiteSpace(fotoUrl) && !fotoUrl.StartsWith("http"))
                {
                    fotoUrl = null;
                }
            }

            @* Renderizado de la Foto (con escudo anti-errores) *@
            <div class="relative w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-bold text-sm ring-2 ring-teal-400 overflow-hidden">
                
                @* 1. La inicial siempre está viva al fondo *@
                <span class="absolute z-0">@(userName.Substring(0, 1).ToUpper())</span>

                @* 2. La foto intenta cargarse por encima *@
                @if (!string.IsNullOrWhiteSpace(fotoUrl))
                {
                    <img src="@fotoUrl" 
                         alt="Perfil" 
                         referrerpolicy="no-referrer"
                         class="absolute z-10 w-full h-full object-cover"
                         onerror="this.style.display='none'" />
                }
            </div>
        </button>

        @* Dropdown Menu *@
        <div id="userMenuDropdown" 
                     class="absolute right-0 top-full mt-2 w-52 
                     bg-white border border-gray-200 
                     rounded-xl shadow-2xl z-50 overflow-hidden 
                     transition-all duration-200 ease-out origin-top-right transform scale-95 opacity-0 invisible">
            <div class="px-4 py-3 border-b border-gray-100">
                @* Aquí solo imprimimos las variables limpias *@
                <p class="text-sm font-semibold text-gray-800 truncate">@userName</p>
                <p class="text-xs text-gray-400 truncate">@userEmail</p>
            </div>
            
            <ul class="py-1">
               @if (tipo == "hibrido" || tipo == "proveedor")
                {
                    <li>
                        <a href="@Url.Action("Index", "Proveedores")" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:translate-x-1 hover:text-teal-600 transition-all">
                            <i class="fas fa-toolbox w-4"></i> Mi dashboard
                        </a>
                    </li>
                }
                <li class="border-t border-gray-100 mt-1">
                    <a href="@Url.Action("Logout", "Account")" class="
                    flex items-center 
                    gap-2 px-4 py-2 
                    text-sm text-red-500 
                    hover:translate-x-1 transition-transform">
                        <i class="fas fa-sign-out-alt w-4"></i> Cerrar sesión
                    </a>
                </li>
            </ul>
        </div>
    </div>
    </div>
}
else
{
    <a href="@Url.Action("Login", "Account")" class="px-6 py-2.5 bg-teal-700 hover:bg-teal-800 text-white text-sm font-bold rounded-full transition-colors shadow-md">
        COMENZAR
    </a>
}

        <button id="bars" class="md:hidden text-teal-700 focus:outline-none">
            <i class="fa-solid fa-bars"></i>
        </button>
    </header>
    @RenderBody()


@if (Request.IsAuthenticated)
{
@* --- BOTÓN FLOTANTE Y VENTANA DE CHAT DE POLA --- *@
<div id="polaChatContainer" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
    
    @* Ventana del Chat (Oculta por defecto) *@
    <div id="polaChatWindow" class="hidden mb-4 w-[350px] sm:w-[340px] h-[600px] rounded-2xl shadow-2xl flex flex-col overflow-hidden border border-white/40 bg-white/70 backdrop-blur-lg transition-all duration-300 origin-bottom-right scale-95 opacity-0">
        
        @* Header Verde (Sin blur para que resalte) *@
        <div class="bg-transparent px-5 py-4 flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-white/60 flex items-center justify-center text-gray-600 font-bold">
                    <i class="fa-solid fa-user-nurse"></i>
                </div>
                <div>
                    <h3 class="text-gray-600 font-bold text-base leading-tight">Beimark</h3>
                    <p class="text-teal-600 text-xs flex items-center gap-1">
                        <span class="w-2 h-2 rounded-full bg-teal-600"></span> En línea
                    </p>
                </div>
            </div>
            <button id="closePolaBtn" class="text-gray-600 hover:text-teal-600 transition">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>

        @* Área de Mensajes *@
        <div id="polaChatMessages" class="flex-1 overflow-y-auto p-5 space-y-4 bg-transparent scroll-smooth">
            @* Mensaje de bienvenida de Beimark *@
            <div class="flex items-end gap-2 w-full">
                <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center text-gray-600 text-xs shrink-0">
                    <i class="fa-solid fa-user-nurse"></i>
                </div>
                <div class="bg-white/80 border border-gray-200 text-gray-700 text-xs py-2 px-4 rounded-2xl rounded-bl-none shadow-md max-w-[85%]">
                    Hola, soy Beimark, tu asistente clínico personal. Fui alertado de una necesidad de suministros en tu clínica. ¿En qué te puedo asesorar hoy? 🫣
                </div>
            </div>
        </div>

        @* Escribiendo... (Oculto por defecto) *@
        <div id="polaTyping" class="hidden px-5 py-2 text-xs text-gray-400 font-medium italic bg-transparent">
            Beimark está escribiendo...
        </div>

        @* Área de Input (Fondo sólido para que se vea claro lo que escribes) *@
        <div class="p-3 bg-white border-t border-gray-100 shrink-0">
            <div class="relative flex items-center">
                <input type="text" id="polaInput" autocomplete="off" placeholder="Escribe tu mensaje..." 
                       class="w-full bg-gray-50 text-sm text-gray-800 rounded-full pl-4 pr-12 py-2 focus:outline-none focus:ring-1 focus:ring-teal-700/50 border border-transparent transition" />
                <button id="polaSendBtn" class="absolute right-2 w-8 h-8 rounded-full bg-teal-700 text-white flex items-center justify-center hover:bg-teal-800 transition">
                    <i class="fa-solid fa-paper-plane text-xs -ml-0.5 mt-0.5"></i>
                </button>
            </div>
        </div>
    </div>

    @* Botón Flotante (FAB) *@
    <button id="polaFabBtn" class="w-12 h-12 rounded-full bg-teal-700 text-white shadow-xl hover:bg-teal-800 hover:scale-105 transition-all flex items-center justify-center group focus:outline-none">
        <i class="fa-regular fa-comments text-xl hidden group-hover:block transition-all"></i>
    </button>
</div>
}

    <footer class="w-full h-fit px-4 md:px-14 py-8 bg-white mt-16">
        <div class="w-full md:flex justify-between">
            <section class="md:w-2/5">
                <h2 class="flex items-center gap-2 text-teal-700 font-bold text-2xl">MediMarket</h2>
                <p class="text-gray-700 hidden md:flex">Digitalizando el suministro médico para un sistema de salud más eficiente y transparente a través de tecnología B2B</p>
            </section>
                <nav class="md:w-3/5 flex justify-end items-end">
                    <div class="flex flex-col md:flex-row text-right md:gap-6">
                    @Html.ActionLink("CARACTERÍSTICAS", "Index", "Home", null, null, "CARACTERiSTICAS", null, new { @class = "text-gray-700 font-medium hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    @Html.ActionLink("CÓMO FUNCIONA", "Index", "Home", null, null, "FUNCION", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    @Html.ActionLink("PRECIOS", "Index", "Home", null, null, "PRECIOS", null, new { @class = "text-gray-700 font-semibold hover:text-teal-800 hover:translate-y-0.5 transition-all" })
                    </div>
                </nav>
        </div>
        <hr class="my-6 border-gray-800" />
        <div>
            <p class="text-center text-gray-700">&copy; @DateTime.Now.Year MediMarket. Todos los derechos reservados.</p>
        </div>
    </footer>   
    <script>
                const btn = document.getElementById('userMenuBtn');
        const dropdown = document.getElementById('userMenuDropdown');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('invisible');
            dropdown.classList.toggle('opacity-0');
            dropdown.classList.toggle('scale-95');
            dropdown.classList.toggle('opacity-100');
            dropdown.classList.toggle('scale-100');
        });

        // Cerrar al hacer clic afuera
        document.addEventListener('click', () => {
            dropdown.classList.add('invisible', 'opacity-0', 'scale-95');
            dropdown.classList.remove('opacity-100', 'scale-100');
        });
        
        dropdown.addEventListener('click', (e) => e.stopPropagation());

        // Lógica del Chat de Pola
document.addEventListener('DOMContentLoaded', () => {
    const fabBtn = document.getElementById('polaFabBtn');
    const closeBtn = document.getElementById('closePolaBtn');
    const chatWindow = document.getElementById('polaChatWindow');
    const chatMessages = document.getElementById('polaChatMessages');
    const chatInput = document.getElementById('polaInput');
    const sendBtn = document.getElementById('polaSendBtn');
    const typingIndicator = document.getElementById('polaTyping');

    // Abrir/Cerrar chat con animación
    const toggleChat = () => {
        chatWindow.classList.toggle('hidden');
        setTimeout(() => {
            chatWindow.classList.toggle('scale-95');
            chatWindow.classList.toggle('opacity-0');
        }, 10);
        if(!chatWindow.classList.contains('hidden')) chatInput.focus();
    };

    fabBtn.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    // Función para pintar burbujitas en el HTML
    const addMessage = (text, isUser) => {
        const msgDiv = document.createElement('div');
        msgDiv.className = `flex items-end gap-2 w-full ${isUser ? 'justify-end' : ''} mb-4`;
        
        let avatarHTML = isUser ? '' : `
            <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center text-gray-700 text-xs shrink-0">
                <i class="fa-solid fa-user-nurse"></i>
            </div>
        `;

        let bubbleHTML = `
            <div class="text-xs py-2 px-4 shadow-md max-w-[85%] 
                ${isUser ? 'bg-gray-300 text-gray-700 rounded-2xl rounded-br-none' 
                         : 'bg-white/80 border border-gray-200 text-gray-700 rounded-2xl rounded-bl-none'}">
                ${text.replace(/\n/g, '<br>')}
            </div>
        `;

        msgDiv.innerHTML = isUser ? bubbleHTML : avatarHTML + bubbleHTML;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight; // Auto-scroll pa' abajo
    };

    // Enviar mensaje al backend
    const sendMessage = () => {
        const text = chatInput.value.trim();
        if (!text) return;

        // 1. Mostrar mensaje del usuario
        addMessage(text, true);
        chatInput.value = '';
        
        // 2. Mostrar "Escribiendo..."
        typingIndicator.classList.remove('hidden');
        chatMessages.scrollTop = chatMessages.scrollHeight;

        // 3. Petición a tu controlador C#
        fetch('/Chat/EnviarMensaje', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mensajeUsuario: text })
        })
        .then(r => r.json())
        .then(data => {
            typingIndicator.classList.add('hidden');
            if (data.ok) {
                addMessage(data.respuesta, false);
            } else {
                addMessage("Ups, me desconecté un segundo. ¿Me lo repites? 🥺", false);
                console.error(data.respuesta);
            }
        })
        .catch(() => {
            typingIndicator.classList.add('hidden');
            addMessage("Parece que mi servidor está durmiendo. 💤 Intenta en un momento.", false);
        });
    };

    // Eventos para enviar (Clic y Enter)
    sendBtn.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
    });
});
    </script>
</body>
</html>
