@model MediMarket.web.Models.proveedores
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = "Configuración";
}

<div class="p-8 max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">Configuración de la Cuenta</h1>
        <p class="text-gray-500 mt-1">Ajusta tus notificaciones, cobros y preferencias de envío.</p>
    </div>

    @if (TempData["ExitoConfig"] != null)
    {
        <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl px-4 py-3 text-sm font-medium">
            <i class="fas fa-check-circle text-lg"></i> @TempData["ExitoConfig"]
        </div>
    }

    @using (Html.BeginForm("Configuracion", "Proveedores", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.id)

        <div class="space-y-6">

            @* ─── TARJETA 1: NOTIFICACIONES ─── *@
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 border-b border-gray-100 px-6 py-4 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center"><i class="fas fa-bell"></i></div>
                    <h3 class="font-bold text-gray-800 text-lg">Preferencias de Notificaciones</h3>
                </div>
                <div class="p-6 space-y-4">
                    <label class="flex items-start gap-3 cursor-pointer group">
                        @Html.CheckBoxFor(m => m.notificar_rfq, new { @class = "mt-1 w-5 h-5 text-teal-600 rounded border-gray-300 focus:ring-teal-500" })
                        <div>
                            <p class="font-bold text-gray-800 group-hover:text-teal-700 transition">Solicitudes de Cotización (RFQ)</p>
                            <p class="text-sm text-gray-500">Avisarme por correo cuando una clínica pida cotizar productos de mi categoría.</p>
                        </div>
                    </label>
                    <label class="flex items-start gap-3 cursor-pointer group">
                        @Html.CheckBoxFor(m => m.notificar_ordenes, new { @class = "mt-1 w-5 h-5 text-teal-600 rounded border-gray-300 focus:ring-teal-500" })
                        <div>
                            <p class="font-bold text-gray-800 group-hover:text-teal-700 transition">Nuevas Órdenes de Compra</p>
                            <p class="text-sm text-gray-500">Notificarme inmediatamente cuando reciba un nuevo pedido.</p>
                        </div>
                    </label>
                    <label class="flex items-start gap-3 cursor-pointer group">
                        @Html.CheckBoxFor(m => m.notificar_inventario, new { @class = "mt-1 w-5 h-5 text-teal-600 rounded border-gray-300 focus:ring-teal-500" })
                        <div>
                            <p class="font-bold text-gray-800 group-hover:text-teal-700 transition">Alertas de Inventario Bajo</p>
                            <p class="text-sm text-gray-500">Avisarme cuando el stock de algún producto esté por agotarse (menos de 10 uds).</p>
                        </div>
                    </label>
                </div>
            </div>

            @* ─── TARJETA 2: DATOS BANCARIOS ─── *@
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 border-b border-gray-100 px-6 py-4 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center"><i class="fas fa-university"></i></div>
                    <h3 class="font-bold text-gray-800 text-lg">Datos Bancarios y Cobros</h3>
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Cuenta CLABE (18 dígitos)</label>
                        @Html.TextBoxFor(m => m.cuenta_clabe, new { @class = "w-full border border-gray-300 rounded-lg py-2.5 px-3 focus:ring-2 focus:ring-teal-500 font-mono tracking-widest", placeholder = "000000000000000000" })
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Banco (Institución)</label>
                        @Html.TextBoxFor(m => m.banco, new { @class = "w-full border border-gray-300 rounded-lg py-2.5 px-3 focus:ring-2 focus:ring-teal-500", placeholder = "Ej. BBVA, Santander" })
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Régimen Fiscal</label>
                        <select name="regimen_fiscal" class="w-full border border-gray-300 rounded-lg py-2.5 px-3 focus:ring-2 focus:ring-teal-500">
                            <option value="">Selecciona tu régimen...</option>
                            <option value="RESICO" @(Model.regimen_fiscal == "RESICO" ? "selected" : "")>Régimen Simplificado de Confianza (RESICO)</option>
                            <option value="Persona Fisica" @(Model.regimen_fiscal == "Persona Fisica" ? "selected" : "")>Persona Física con Actividad Empresarial</option>
                            <option value="Persona Moral" @(Model.regimen_fiscal == "Persona Moral" ? "selected" : "")>Persona Moral (General de Ley)</option>
                        </select>
                    </div>
                </div>
            </div>

            @* ─── TARJETA 3: LOGÍSTICA ─── *@
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 border-b border-gray-100 px-6 py-4 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center"><i class="fas fa-truck-fast"></i></div>
                    <h3 class="font-bold text-gray-800 text-lg">Logística y Envíos</h3>
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Días de Preparación</label>
                        <div class="flex items-center gap-2">
                            @Html.TextBoxFor(m => m.dias_preparacion, new { @type = "number", @min = "1", @class = "w-24 border border-gray-300 rounded-lg py-2.5 px-3 focus:ring-2 focus:ring-teal-500 text-center font-bold" })
                            <span class="text-sm text-gray-600 font-medium">días hábiles para despachar.</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Monto para Envío Gratis (Opcional)</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="text-gray-500 sm:text-sm">$</span>
                            </div>
                            @Html.TextBoxFor(m => m.monto_envio_gratis, new { @type = "number", @step = "0.01", @class = "w-full pl-7 border border-gray-300 rounded-lg py-2.5 px-3 focus:ring-2 focus:ring-teal-500", placeholder = "Ej. 2500.00" })
                        </div>
                        <p class="text-xs text-gray-400 mt-1">Déjalo en blanco si no ofreces envío gratis por volumen.</p>
                    </div>
                </div>
            </div>

            @* ─── BOTÓN DE GUARDAR ─── *@
            <div class="flex justify-end pt-4">
                <button type="submit" class="bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 px-8 rounded-xl transition shadow-sm text-lg">
                    <i class="fas fa-save mr-2"></i> Guardar Configuración
                </button>
            </div>

        </div>
    }
</div>