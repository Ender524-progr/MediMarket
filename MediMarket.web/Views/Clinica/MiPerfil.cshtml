@model MediMarket.web.Models.clinicas

@{
    ViewBag.Title = "Mi Clínica";
    Layout = "~/Views/Shared/_LayoutShop.cshtml";
}

@* ──────────────── TOAST DE ÉXITO ──────────────── *@
@if (TempData["Exito"] != null)
{
    <div id="toastExito" class="
    fixed top-20 right-6 z-50 flex items-center w-full max-w-xs p-4 space-x-3 
    bg-white border-l-4 border-teal-500 
    rounded-xl shadow-lg transition-opacity duration-300">
        <div class="
        inline-flex items-center justify-center shrink-0 w-8 h-8
         text-teal-500 bg-teal-100 rounded-lg">
            <i class="fa-solid fa-check"></i>
        </div>
        <div class="ml-3 text-sm font-semibold text-gray-700">
            @TempData["Exito"]
        </div>
    </div>

    <script>
        // Hacemos que desaparezca suavemente después de 2 segundos (2000 ms)
        setTimeout(() => {
            const toast = document.getElementById('toastExito');
            if (toast) {
                toast.classList.add('opacity-0'); // Empieza a desvanecerse
                setTimeout(() => toast.remove(), 300); // Lo borramos del HTML después de la animación
            }
        }, 2000);
    </script>
}

<div class="max-w-3xl mx-auto py-10 pt-20">

<a href="@Url.Action("Index", "Shop")" class="inline-flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-teal-600 transition-colors mb-6 group">
        <i class="fa-solid fa-arrow-left-long group-hover:-translate-x-1 transition-transform"></i> Seguir comprando
    </a>

    <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-800">Perfil de la Clínica</h2>
        <p class="text-sm text-gray-500">Administra los datos de tu institución médica.</p>
    </div>

    @* Formulario de Edición *@
    @using (Html.BeginForm("MiPerfil", "Clinica", FormMethod.Post, new { @class = "bg-white rounded-2xl border border-gray-200 shadow-sm p-8 space-y-6" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.id)

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @* Nombre *@
            <div class="md:col-span-2">
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Nombre de la Clínica *</label>
                @Html.TextBoxFor(m => m.nombre_clinica, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:bg-white" })
            </div>

            @* Especialidad y RFC *@
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Especialidad</label>
                @Html.TextBoxFor(m => m.especialidad, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" })
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">RFC</label>
                @Html.TextBoxFor(m => m.rfc, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-teal-500" })
            </div>

            @* Dirección y Teléfono *@
            <div class="md:col-span-2">
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Dirección completa</label>
                @Html.TextBoxFor(m => m.direccion, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" })
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Teléfono</label>
                @Html.TextBoxFor(m => m.telefono, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" })
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Ciudad</label>
                @Html.TextBoxFor(m => m.ciudad, new { @class = "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" })
            </div>
        </div>

        @* Botones de Acción *@
        <div class="flex items-center justify-between pt-6 border-t border-gray-100 mt-8">
            <button type="button" onclick="document.getElementById('modalEliminar').classList.remove('hidden')" 
                    class="px-4 py-2.5 rounded-xl border border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 text-sm font-semibold transition-colors flex items-center gap-2">
                <i class="fa-solid fa-trash"></i> Eliminar mi cuenta
            </button>

            <button type="submit" class="px-6 py-2.5 rounded-xl bg-teal-600 hover:bg-teal-700 text-white text-sm font-semibold transition-colors shadow-md flex items-center gap-2">
                <i class="fa-solid fa-floppy-disk"></i> Guardar cambios
            </button>
        </div>
    }
</div>

@* ──────────────── MODAL DE ELIMINACIÓN ──────────────── *@
<div id="modalEliminar" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900/40 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full mx-4 text-center">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4 text-red-500 text-2xl">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Eliminar cuenta</h3>
        <p class="text-sm text-gray-500 mb-6">
            Esta acción es irreversible y borrará permanentemente tus datos de usuario así como tu(s) clínica(s) e historial.
        </p>

        @using (Html.BeginForm("EliminarCuenta", "Clinica", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="flex gap-3 w-full">
                <button type="button" onclick="document.getElementById('modalEliminar').classList.add('hidden')" 
                        class="flex-1 px-4 py-2.5 border border-gray-200 rounded-xl text-gray-600 font-semibold text-sm hover:bg-gray-50">
                    Cancelar
                </button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-red-500 hover:bg-red-600 rounded-xl text-white font-semibold text-sm shadow-sm transition-colors">
                    Sí, eliminar
                </button>
            </div>
        }
    </div>
</div>