@model MediMarket.web.Models.solicitudes_rfq
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = Model.titulo;

    var miCotizacion = ViewBag.MiCotizacion as MediMarket.web.Models.cotizaciones;
    var proveedorId = (Guid?)ViewBag.ProveedorId;
    bool estaAbierta = Model.estado == "abierta";
    bool yaCotizo = miCotizacion != null;
}

@helper BadgeEstado(string estado)
{
    string cls, label;
    switch (estado)
    {
        case "abierta": cls = "bg-emerald-100 text-emerald-700"; label = "ABIERTA"; break;
        case "en_revision": cls = "bg-blue-100 text-blue-700"; label = "EN REVISIÓN"; break;
        case "cerrada": cls = "bg-gray-200 text-gray-500"; label = "CERRADA"; break;
        case "adjudicada": cls = "bg-purple-100 text-purple-700"; label = "ADJUDICADA"; break;
        default: cls = "bg-gray-100 text-gray-500"; label = estado.ToUpper(); break;
    }
    <span class="text-xs font-bold px-2.5 py-1 rounded-full @cls">@label</span>
}

<div class="p-8 max-w-4xl mx-auto">

    @* Navegación *@
    <a href="@Url.Action("Index", "RFQs")"
       class="text-sm text-gray-400 hover:text-gray-700 flex items-center gap-1 mb-6">
        <i class="fas fa-arrow-left text-xs"></i> Volver a RFQs
    </a>

    @if (TempData["Exito"] != null)
    {
        <div class="mb-4 flex items-center gap-3 bg-emerald-50 border border-emerald-200
                    text-emerald-700 rounded-xl px-4 py-3 text-sm font-medium">
            <i class="fas fa-check-circle text-lg"></i>
            @TempData["Exito"]
        </div>
    }

    <div class="grid grid-cols-3 gap-6">

        @* ── Columna izquierda: detalles de la RFQ ───────────────────────── *@
        <div class="col-span-2 space-y-5">

            @* Header *@
            <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800">@Model.titulo</h1>
                        <p class="text-sm text-gray-400 mt-1">
                            Publicada el @Model.creado_en.ToString("dd 'de' MMMM 'de' yyyy")
                        </p>
                    </div>
                    @BadgeEstado(Model.estado)
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.descripcion))
                {
                    <p class="mt-4 text-gray-600 leading-relaxed">@Model.descripcion</p>
                }

                <div class="grid grid-cols-3 gap-3 mt-5">
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-xs text-gray-400 uppercase font-semibold">Categoría</p>
                        <p class="font-semibold text-gray-800 mt-0.5">@(Model.categorias?.nombre ?? "—")</p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-xs text-gray-400 uppercase font-semibold">Cantidad estimada</p>
                        <p class="font-semibold text-gray-800 mt-0.5">@(Model.cantidad_estimada ?? "—")</p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3">
                        <p class="text-xs text-gray-400 uppercase font-semibold">Fecha límite</p>
                        @if (Model.fecha_limite.HasValue)
                        {
                            bool urgente = Model.fecha_limite.Value <= DateTime.Today.AddDays(3);
                            <p class="font-semibold mt-0.5 @(urgente ? "text-red-500" : "text-gray-800")">
                                @Model.fecha_limite.Value.ToString("dd MMM yyyy")
                                @if (urgente && estaAbierta)
                                {
                                    <span class="text-xs font-normal ml-1">⚠️ Pronto</span>
                                }
                            </p>
                        }
                        else
                        {
                            <p class="font-semibold text-gray-800 mt-0.5">—</p>
                        }
                    </div>
                </div>
            </div>

            @* Clínica solicitante *@
            <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">Solicitante</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center">
                        <i class="fas fa-clinic-medical text-teal-600"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-800">@(Model.clinicas?.nombre_clinica ?? "—")</p>
                        <p class="text-xs text-gray-400">@(Model.clinicas?.especialidad ?? "")</p>
                    </div>
                </div>
            </div>

            @* Otras cotizaciones recibidas (anónimas) *@
            @{
                var otrasCot = Model.cotizaciones?
                    .Where(c => c.proveedor_id != proveedorId)
                    .ToList() ?? new List<MediMarket.web.Models.cotizaciones>();
            }
            @if (otrasCot.Any())
            {
                <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">
                        Cotizaciones recibidas
                        <span class="ml-1 bg-teal-100 text-teal-700 px-1.5 py-0.5 rounded-full">@otrasCot.Count</span>
                    </p>
                    <div class="space-y-2">
                        @foreach (var cot in otrasCot.OrderBy(c => c.monto))
                        {
                            <div class="flex items-center justify-between py-2 px-3 bg-gray-50 rounded-lg text-sm">
                                <span class="text-gray-500">Proveedor anónimo</span>
                                <div class="flex items-center gap-4">
                                    <span class="font-bold text-gray-800">$@cot.monto.ToString("N2")</span>
                                    <span class="text-gray-400">@(cot.tiempo_entrega ?? "—")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── Columna derecha: formulario de cotización ───────────────────── *@
        @* ── Columna derecha: detalle y formulario de cotización ───────────────────── *@
        <div class="space-y-4">
            
            @* 1. NUEVO: Tarjeta de "Mi Cotización" (Siempre visible si ya cotizó) *@
            @if (yaCotizo)
            {
                <div class="bg-teal-50 border border-teal-200 rounded-xl p-5 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="font-bold text-teal-800">
                            <i class="fas fa-file-invoice-dollar mr-1"></i> Mi Cotización
                        </h2>
                        <span class="bg-teal-200 text-teal-800 text-xs font-bold px-2.5 py-1 rounded-full uppercase">
                            @miCotizacion.estado
                        </span>
                    </div>

                    <div class="space-y-3 text-sm text-teal-900">
                        <div class="flex justify-between items-center border-b border-teal-100 pb-2">
                            <span class="font-medium text-teal-700">Monto ofertado:</span>
                            <span class="font-bold text-lg">$@miCotizacion.monto.ToString("N2")</span>
                        </div>
                        <div class="flex justify-between items-center border-b border-teal-100 pb-2">
                            <span class="font-medium text-teal-700">Tiempo de entrega:</span>
                            <span class="font-semibold">@(miCotizacion.tiempo_entrega ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(miCotizacion.notas))
                        {
                            <div class="pt-1">
                                <span class="font-medium text-teal-700 block mb-1">Notas adicionales:</span>
                                <p class="text-teal-800 bg-white/60 p-2.5 rounded-lg border border-teal-100/50">@miCotizacion.notas</p>
                            </div>
                        }
                        <div class="pt-2 text-xs text-teal-600 text-right font-medium">
                            Enviada el: @miCotizacion.creado_en.ToString("dd MMM yyyy, HH:mm")
                        </div>
                    </div>
                </div>
            }

            @* 2. Formulario para nueva cotización o actualizar una existente *@
            @if (!estaAbierta)
            {
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 text-center text-gray-400">
                    <i class="fas fa-lock text-3xl mb-2 opacity-40"></i>
                    <p class="text-sm font-medium">Esta RFQ ya no acepta nuevas cotizaciones ni modificaciones.</p>
                </div>
            }
            else
            {
                <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                    <h2 class="font-bold text-gray-800 mb-4">
                        @(yaCotizo ? "✏️ Modificar propuesta" : "📝 Enviar cotización")
                    </h2>

                    @using (Html.BeginForm("Cotizar", "RFQs", FormMethod.Post, new { @class = "space-y-4" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="rfqId" value="@Model.id" />

                        @* Monto *@
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">
                                Monto total <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-gray-400 text-sm">$</span>
                                <input type="number" name="monto" step="0.01" min="0" required
                                       value="@(miCotizacion?.monto.ToString("F2") ?? "")"
                                       placeholder="0.00"
                                       class="w-full pl-7 pr-3 py-2 border rounded-lg text-sm
                                              focus:outline-none focus:ring-2 focus:ring-teal-400" />
                            </div>
                        </div>

                        @* Tiempo de entrega *@
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Tiempo de entrega</label>
                            <input type="text" name="tiempoEntrega"
                                   value="@(miCotizacion?.tiempo_entrega ?? "")"
                                   placeholder="Ej. 3-5 días hábiles"
                                   class="w-full border rounded-lg py-2 px-3 text-sm
                                          focus:outline-none focus:ring-2 focus:ring-teal-400" />
                        </div>

                        @* Notas *@
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Notas adicionales</label>
                            <textarea name="notas" rows="3"
                                      placeholder="Condiciones, garantías, aclaraciones..."
                                      class="w-full border rounded-lg py-2 px-3 text-sm resize-none
                                             focus:outline-none focus:ring-2 focus:ring-teal-400">@(miCotizacion?.notas ?? "")</textarea>
                        </div>

                        <button type="submit"
                                class="w-full py-2.5 rounded-lg bg-teal-600 hover:bg-teal-700
                                       text-white font-bold text-sm transition active:scale-95">
                            <i class="fas fa-paper-plane mr-1"></i>
                            @(yaCotizo ? "Actualizar cotización" : "Enviar cotización")
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>
