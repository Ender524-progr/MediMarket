
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<main class="w-full min-h-screen gap-8  pt-24
flex flex-col justify-center items-center 
text-white bg-gray-200">

    <section class="flex items-center justify-center gap-2">

        <div class="
        p-1 rounded-md 
        text-teal-700 text-2xl">
            <i class="
            fa-solid fa-briefcase-medical"></i>
        </div>
        <h2 class="
        font-bold text-2xl text-teal-700">MediMarket</h2>
    </section>

    <section class="
    w-fit h-fit 
    flex flex-col justify-center items-center gap-8 
    py-14 px-8 rounded-2xl
    bg-white shadow-md">
        
        <div class="flex flex-col items-center">
            
            <h1 class="text-2xl font-semibold text-black px-16">Bienvenido a MediMarket</h1>
            <p class="
            text-gray-600 
            max-w-xs font-medium text-center 
            py-2">
            Accede con tu cuenta para continuar</p>
        </div>

        @using (Html.BeginForm("LoginConGoogle", "Account", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <button type="submit" class="w-full bg-gray-300 rounded-xl 
        py-4 px-22 flex justify-center items-center gap-2         
        text-lg font-semibold text-black 
        border border-gray-300
        hover:border-teal-800 hover:bg-teal-600/10 transition-colors">
         <i class="fa-brands fa-google"></i>
        <span class="font-bold text-on-surface">Iniciar sesión con Google</span>
    </button>
}       

    <div class="
    w-full max-w-md 
    flex
    p-4 rounded-xl
    text-emerald-600
    bg-teal-50 
    border-teal-100 border-2
    ">
    <div class="p-2">
        <i class="fa-solid fa-shield-halved"></i>
    </div>        
        <p class="font-semibold text-sm">Tu cuenta está verificada para garantizar confianza en la plataforma y cumplir con las políticas de uso</p>
    </div>

    </section>
    <section class="pb-12">
        <p class="max-w-sm text-center text-sm text-gray-400">Al continuar, aceptas nuestros <a href="" class="text-teal-700">Términos y Condiciones</a> y nuestra Politica de privacidad</p>
    </section>
</main>
