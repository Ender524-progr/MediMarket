<script>
    function mostrarForm(tipo) {
        document.getElementById('selector-rol').style.display = 'none';
        document.getElementById('form-clinica').style.display = (tipo === 'clinica') ? 'block' : 'none';
        document.getElementById('form-proveedor').style.display = (tipo === 'proveedor') ? 'block' : 'none';
        document.getElementById('form-hibrido').style.display = (tipo === 'hibrido') ? 'block' : 'none';
    }

    function regresar() {
        document.getElementById('selector-rol').style.display = 'grid';
        document.getElementById('form-clinica').style.display = 'none';
        document.getElementById('form-proveedor').style.display = 'none';
        document.getElementById('form-hibrido').style.display = 'none';
    }

    // FUNCIÓN MAESTRA DEL CÓDIGO POSTAL (Reutilizable y sin errores de copy-paste)
    function habilitarAutocompletadoCP(inputId, loadingId, selectColoniaId, inputEstadoId) {
        const inputElement = document.getElementById(inputId);
        if (!inputElement) return;

        inputElement.addEventListener('input', async function (e) {
            const cp = e.target.value;

            if (cp.length === 5) {
                const loading = document.getElementById(loadingId);
                const selectColonia = document.getElementById(selectColoniaId);
                const inputEstado = document.getElementById(inputEstadoId);

                loading.style.display = 'block';

                try {
                    const response = await fetch(`https://api.zippopotam.us/mx/${cp}`);
                    if (!response.ok) throw new Error("La API no encontró el CP");

                    const data = await response.json();

                    if (data && data.places && data.places.length > 0) {
                        inputEstado.value = data.places[0].state;

                        selectColonia.innerHTML = '<option value="">Selecciona tu colonia</option>';
                        data.places.forEach(place => {
                            const option = document.createElement('option');
                            option.value = place["place name"];
                            option.textContent = place["place name"];
                            selectColonia.appendChild(option);
                        });
                    }
                } catch (error) {
                    console.warn(`Plan B activado para ${inputId}:`, error);
                    inputEstado.value = "Chiapas";

                    selectColonia.innerHTML = '<option value="">Selecciona tu colonia</option>';
                    const coloniasPrueba = ["Centro", "San Francisco", "Los Lagos", "Evolución"];
                    coloniasPrueba.forEach(col => {
                        const option = document.createElement('option');
                        option.value = col;
                        option.textContent = col;
                        selectColonia.appendChild(option);
                    });
                } finally {
                    loading.style.display = 'none';
                }
            }
        });
    }

    habilitarAutocompletadoCP('cp_clinica', 'loading_cp', 'colonia_clinica', 'estado_clinica');
    habilitarAutocompletadoCP('cp_proveedor', 'loading_cp_proveedor', 'colonia_proveedor', 'estado_proveedor');
    habilitarAutocompletadoCP('cp_hibrido', 'loading_cp_hibrido', 'colonia_hibrido', 'estado_hibrido');

    function habilitarValidaciones() {

        const reglas = {
            'rfc': {
                regex: /^([A-ZÑ&]{3,4}) ?(?:- ?)?(\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\d|3[01])) ?(?:- ?)?([A-Z\d]{2})([A\d])$/i,
                mensaje: 'RFC inválido. Deben ser 12 o 13 caracteres correctos.'
            },
            'telefono': {
                regex: /^\d{10}$/,
                mensaje: 'El teléfono debe tener exactamente 10 números.'
            },
            'cedula': {
                regex: /^\d{7,8}$/,
                mensaje: 'La cédula debe tener 7 u 8 números.'
            }
        };

        Object.keys(reglas).forEach(campo => {
            const inputs = document.querySelectorAll(`input[name="${campo}"]`);

            inputs.forEach(input => {
                const errorSpan = document.createElement('span');
                errorSpan.className = 'text-xs text-red-500 font-bold mt-1 hidden w-full block';
                input.parentNode.appendChild(errorSpan);

                input.addEventListener('input', function (e) {
                    const valor = e.target.value.trim();
                    const regla = reglas[campo];

                    if (valor === '') {
                        errorSpan.classList.add('hidden');
                        input.classList.remove('border-red-500', 'border-green-500', 'bg-red-50', 'bg-green-50');
                        return;
                    }

                    if (!regla.regex.test(valor)) {
                        errorSpan.textContent = regla.mensaje;
                        errorSpan.classList.remove('hidden');
                        input.classList.add('border-red-500', 'bg-red-50');
                        input.classList.remove('border-green-500', 'bg-green-50');
                    } else {
                        errorSpan.classList.add('hidden');
                        input.classList.remove('border-red-500', 'bg-red-50');
                        input.classList.add('border-green-500', 'bg-green-50');
                    }
                });
            });
        });
    }

    habilitarValidaciones();
</script>