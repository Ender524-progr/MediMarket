@{
    ViewBag.Title = "Home";
}
<main class="min-h-dvh">
    <header>
        <img src="~/Content/Images/medicos.png" alt="Imagen de fondo" class="w-full h-auto object-cover">

        <section class="flex justify-center content-center flex-col items-center absolute top-0 left-0 pt-10 w-full h-full text-center text-white px-4">
            <div class="bg-white/10 backdrop-blur-md px-6 py-3 rounded-4xl border-2 border-gray-300/40 font-semibold">
                <span class="text-sm text-teal-400 m-1 animate-pulse">
                    <i class="fa-solid fa-circle"></i>
                </span>                
                LÍDER EN SUMINISTROS MÉDICOS B2B
            </div>
            <div class="pt-4 text-4xl md:text-7xl font-bold leading-tight">
                <h1 class="pt-3 text-5xl md:text-7xl font-bold leading-tight">
                  Conecta con 
                <br/>
                <span class="text-teal-300">proveedores</span> 
                <br/>
                  verificados.
                </h1>
                <p class="mt-8 text-lg md:text-xl font-medium max-w-xl mx-auto leading-relaxed">
                    La infraestructura digital para que las instutuciones de salud gestionen adquisiciones con transparecia, seguridad y eficiencia total.
                </p>
            </div>
             <a href="@Url.Action("accion", "controlador")" class="text-xl mt-14 bg-teal-700 rounded-2xl px-8 py-4 text-white font-semibold hover:bg-teal-800 flex items-center justify-center gap-2 hover:translate-x-1 transition-all">               
                Crear cuenta gratuita
                <i class="fa-solid fa-arrow-right"></i>
             </a>
        </section>
    </header>
</main>
