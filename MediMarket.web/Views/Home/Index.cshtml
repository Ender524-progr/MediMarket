@{
    ViewBag.Title = "Home";
}
<main class="min-h-dvh font-sans">
    <header class="relative w-full h-dvh">
        <img src="~/Content/Images/medicos.png" alt="Imagen de fondo" class="w-full h-dvh object-cover">

        <section class="flex justify-center content-center flex-col items-center absolute top-0 left-0  w-full h-dvh text-center text-white px-4 pt-14 gap-6">
            <div class="flex items-center bg-white/10 backdrop-blur-md px-3 py-1.5 rounded-4xl border-2 border-gray-300/40 font-semibold gap-2">
                <span class="w-3.5 h-3.5 text-sm text-teal-400  animate-pulse flex items-center justify-center">
                    <i class="fa-solid fa-circle"></i>
                </span>                
                <p class="text-xs md:text-lg">LÍDER EN SUMINISTROS MÉDICOS B2B</p>
            </div>
            <div class="font-bold leading-tight flex flex-col gap-4">
                <h2 class="max-w-xl text-4xl md:text-6xl leading-tight">
                    Conecta con 
                <span class="text-teal-300 md:text-7xl">proveedores</span> 
                    verificados.
                </h2>
                <p class="text-sm md:text-lg font-medium max-w-xl mx-auto leading-relaxed">
                    La infraestructura digital para que las instutuciones de salud gestionen adquisiciones con transparecia, seguridad y eficiencia total.
                </p>
            </div>
             <a href="@Url.Action("accion", "controlador")" class="text-lg md:text-xl bg-teal-700 rounded-2xl px-8 py-4 text-white font-semibold hover:bg-teal-800 flex items-center justify-center gap-2 hover:translate-x-1 transition-all">               
                Crear cuenta gratuita
                <i class="fa-solid fa-arrow-right"></i>
             </a>
        </section>
    </header>
    <section class="w-full h-1/2
                    flex flex-col items-center
                    py-8 gap-4">
        <h2 class="font-mono text-xl">ESTANDARES DE SEGURIDAD INTEGRADOS</h2>
        <div class="flex not-md:flex-col items-center md:justify-around
                    w-full ">
            <article class="flex items-center
                            gap-2
                            font-semibold">
                <i class="fa-solid fa-shield-alt text-2xl"></i>
                <h3 class="text-xl">Proveedores Verificados</h3>
            </article>
            <article class="flex items-center
                            gap-2
                            font-semibold">
                <i class="fa-solid fa-lock text-2xl"></i>
                <h3 class="text-xl">Transacciones Seguras</h3>
            </article>
            <article class="flex items-center
                            gap-2
                            font-semibold">
                <i class="fa-solid fa-user-shield text-2xl"></i>
                <h3 class="text-xl">Protección de Datos</h3>
            </article>
        </div>
    </section>
</main>
