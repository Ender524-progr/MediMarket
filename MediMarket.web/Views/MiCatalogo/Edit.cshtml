@model MediMarket.web.Models.ViewModels.ProductoViewModel
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = "Editar Producto";
}

<div class="p-8 max-w-3xl mx-auto">
    <div class="mb-6">
        <a href="@Url.Action("Index", "MiCatalogo")" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
            <i class="fas fa-arrow-left text-xs"></i> Volver al catálogo
        </a>
        <h1 class="text-3xl font-bold mt-2">Editar Producto</h1>
        <p class="text-gray-500">Modifique la información del producto.</p>
    </div>

    @using (Html.BeginForm("Edit", "MiCatalogo", FormMethod.Post, new { enctype = "multipart/form-data", @class = "space-y-6" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        @* Nombre *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre <span class="text-red-500">*</span></label>
            @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-red-500 text-sm" })
        </div>

        @* Descripción *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Descripción</label>
            @Html.TextAreaFor(m => m.Descripcion, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500 resize-none", rows = "3" })
        </div>

        @* SKU y Categoría *@
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">SKU</label>
                @Html.TextBoxFor(m => m.Sku, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" })
            </div>
            <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1">Categoría</label>
    <select name="CategoriaId" id="CategoriaId" class="w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <option value="">— Sin categoría —</option>
        @if (Model.Categorias != null)
        {
            foreach (var padre in Model.Categorias.Where(c => c.padre_id == null))
            {
                <optgroup label="@padre.nombre">
                    @foreach (var hijo in Model.Categorias.Where(c => c.padre_id == padre.id))
                    {
                        <option value="@hijo.id" @(Model.CategoriaId == hijo.id ? "selected" : "")>@hijo.nombre</option>
                    }
                </optgroup>
            }
        }
    </select>
</div>
        </div>

        @* Precio, Unidad y Stock *@
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Precio unitario <span class="text-red-500">*</span></label>
                <div class="relative">
                    <span class="absolute left-3 top-2 text-gray-400">$</span>
                    @Html.TextBoxFor(m => m.PrecioUnitario, new { @class = "w-full border rounded-lg py-2 pl-7 pr-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", type = "number", step = "0.01", min = "0" })
                </div>
                @Html.ValidationMessageFor(m => m.PrecioUnitario, "", new { @class = "text-red-500 text-sm" })
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Unidad de medida <span class="text-red-500">*</span></label>
                @Html.DropDownListFor(m => m.UnidadMedida,
                    new SelectList(new[] { "pieza", "caja", "paquete", "litro", "mililitro", "gramo", "kilogramo", "servicio" }, Model.UnidadMedida),
                    new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" })
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Stock disponible</label>
                @Html.TextBoxFor(m => m.StockDisponible, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", type = "number", min = "0" })
            </div>
        </div>

        @* Imágenes actuales *@
        if (Model.ImagenesActuales != null && Model.ImagenesActuales.Any())
        {
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Imágenes actuales</label>
                <p class="text-xs text-gray-400 mb-3">Marca las imágenes que deseas eliminar.</p>
                <div class="flex gap-3 flex-wrap">
                    @foreach (var img in Model.ImagenesActuales)
                    {
                        <div class="relative group">
                            <img src="@img.url" class="w-24 h-24 object-cover rounded-lg border">
                            @if (img.es_principal)
                            {
                                <span class="absolute top-1 left-1 bg-emerald-600 text-white text-xs px-1 rounded">Principal</span>
                            }
                            <label class="absolute inset-0 flex items-center justify-center bg-red-500/0 group-hover:bg-red-500/40 rounded-lg transition cursor-pointer">
                                <input type="checkbox" name="ImagenesEliminar" value="@img.id"
                                       class="hidden peer" />
                                <span class="opacity-0 group-hover:opacity-100 text-white text-xs font-bold">Eliminar</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        }

        @* Nuevas imágenes *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Agregar nuevas imágenes</label>
            <input type="file" name="Imagenes" multiple accept=".jpg,.jpeg,.png,.webp"
                   class="w-full border border-dashed rounded-lg py-3 px-4 text-gray-500 focus:outline-none cursor-pointer" />
            <div id="preview" class="flex gap-2 mt-3 flex-wrap"></div>
        </div>

        @* Activo *@
        <div class="flex items-center gap-3">
            @Html.CheckBoxFor(m => m.Activo, new { @class = "w-4 h-4 accent-emerald-600" })
            <label class="text-sm font-semibold text-gray-700">Publicar producto (visible en el marketplace)</label>
        </div>

        @* Acciones *@
        <div class="flex justify-end gap-3 pt-4 border-t">
            <a href="@Url.Action("Index", "MiCatalogo")"
               class="py-2 px-6 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold">
                Cancelar
            </a>
            <button type="submit"
                    class="py-2 px-6 rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-bold">
                Guardar cambios
            </button>
        </div>
    }
</div>

<script>
    // Preview de nuevas imágenes
    document.querySelector('input[type=file]').addEventListener('change', function () {
        const preview = document.getElementById('preview');
        preview.innerHTML = '';
        Array.from(this.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'w-20 h-20 object-cover rounded-lg border';
                preview.appendChild(img);
            };
            reader.readAsDataURL(file);
        });
    });

    // Marcar visualmente las imágenes para eliminar
    document.querySelectorAll('input[name=ImagenesEliminar]').forEach(cb => {
        cb.addEventListener('change', function () {
            const imgEl = this.closest('.relative').querySelector('img');
            imgEl.classList.toggle('opacity-40', this.checked);
            imgEl.classList.toggle('ring-2', this.checked);
            imgEl.classList.toggle('ring-red-500', this.checked);
        });
    });
</script>
