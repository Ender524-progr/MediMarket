@model MediMarket.web.Models.ViewModels.ProductoViewModel
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = "Agregar Producto";
}

<div class="p-8 max-w-3xl mx-auto">
    <div class="mb-6">
        <a href="@Url.Action("Index", "MiCatalogo")" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
            <i class="fas fa-arrow-left text-xs"></i> Volver al catálogo
        </a>
        <h1 class="text-3xl font-bold mt-2">Agregar Producto</h1>
        <p class="text-gray-500">Complete la información del producto o servicio.</p>
    </div>

    @using (Html.BeginForm("Create", "MiCatalogo", FormMethod.Post, new { enctype = "multipart/form-data", @class = "space-y-6" }))
    {
        @Html.AntiForgeryToken()

        @* Nombre *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre <span class="text-red-500">*</span></label>
            @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder = "Ej. Guantes de látex talla M" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-red-500 text-sm" })
        </div>

        @* Descripción *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Descripción</label>
            @Html.TextAreaFor(m => m.Descripcion, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500 resize-none", rows = "3", placeholder = "Descripción breve del producto..." })
        </div>

        @* SKU y Categoría en fila *@
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">SKU</label>
                @Html.TextBoxFor(m => m.Sku, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder = "Ej. GLT-M-100" })
            </div>
            <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1">Categoría</label>
    <select name="CategoriaId" id="CategoriaId" class="w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <option value="">— Sin categoría —</option>
        @if (Model.Categorias != null)
        {
            // Primero obtenemos las categorías principales (las que no tienen padre)
            foreach (var padre in Model.Categorias.Where(c => c.padre_id == null))
            {
                <optgroup label="@padre.nombre">
                    // Luego iteramos sobre las subcategorías que pertenecen a este padre
                    @foreach (var hijo in Model.Categorias.Where(c => c.padre_id == padre.id))
                    {
                        <option value="@hijo.id">@hijo.nombre</option>
                    }
                </optgroup>
            }
        }
    </select>
</div>
        </div>

        @* Precio, Unidad y Stock en fila *@
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Precio unitario <span class="text-red-500">*</span></label>
                <div class="relative">
                    <span class="absolute left-3 top-2 text-gray-400">$</span>
                    @Html.TextBoxFor(m => m.PrecioUnitario, new { @class = "w-full border rounded-lg py-2 pl-7 pr-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", type = "number", step = "0.01", min = "0" })
                </div>
                @Html.ValidationMessageFor(m => m.PrecioUnitario, "", new { @class = "text-red-500 text-sm" })
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Unidad de medida <span class="text-red-500">*</span></label>
                @Html.DropDownListFor(m => m.UnidadMedida,
                    new SelectList(new[] { "pieza", "caja", "paquete", "litro", "mililitro", "gramo", "kilogramo", "servicio" }),
                    new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" })
                @Html.ValidationMessageFor(m => m.UnidadMedida, "", new { @class = "text-red-500 text-sm" })
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Stock disponible</label>
                @Html.TextBoxFor(m => m.StockDisponible, new { @class = "w-full border rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-emerald-500", type = "number", min = "0" })
            </div>
        </div>

        @* Imágenes *@
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Imágenes del producto</label>
            <p class="text-xs text-gray-400 mb-2">Formatos: JPG, PNG, WEBP. La primera imagen será la principal.</p>
            <input type="file" name="Imagenes" multiple accept=".jpg,.jpeg,.png,.webp"
                   class="w-full border border-dashed rounded-lg py-3 px-4 text-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 cursor-pointer" />
            <div id="preview" class="flex gap-2 mt-3 flex-wrap"></div>
        </div>

        @* Activo *@
        <div class="flex items-center gap-3">
            @Html.CheckBoxFor(m => m.Activo, new { @class = "w-4 h-4 accent-emerald-600" })
            <label class="text-sm font-semibold text-gray-700">Publicar producto (visible en el marketplace)</label>
        </div>

        @* Acciones *@
        <div class="flex justify-end gap-3 pt-4 border-t">
    <a href="@Url.Action("Index", "MiCatalogo")"
       class="py-2 px-6 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold">
        Cancelar
    </a>
    
    <button type="button" onclick="generarPreview()"
            class="py-2 px-6 rounded-lg bg-teal-50 text-teal-700 border border-teal-200 hover:bg-teal-100 font-bold transition">
        <i class="fas fa-eye mr-1"></i> Preview
    </button>

    <button type="submit"
            class="py-2 px-6 rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-bold">
        Guardar producto
    </button>
</div>
    }
</div>

<div id="modalPreview" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 hidden">
    <div class="bg-white rounded-2xl max-w-5xl w-full mx-4 max-h-[90vh] overflow-y-auto relative shadow-2xl">
        <button type="button" onclick="cerrarPreview()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-full w-8 h-8 flex items-center justify-center transition">
            <i class="fas fa-times"></i>
        </button>

        <div class="p-8">
            <div class="text-xs text-gray-400 mb-6 flex gap-2">
                <span>Marketplace</span> › <span id="p_cat_bread">Categoría</span> › <span id="p_nom_bread" class="font-semibold text-gray-700">Producto</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div>
                    <div class="border border-gray-200 rounded-xl overflow-hidden aspect-[4/3] flex items-center justify-center p-4 bg-gray-50">
                        <img id="p_img" src="/Content/img/no-image.png" class="max-h-full object-contain" />
                    </div>
                </div>

                <div class="flex flex-col">
                    <div class="flex items-center gap-3 mb-2">
                        <span id="p_cat_tag" class="bg-gray-100 text-gray-600 text-xs font-bold px-2.5 py-1 rounded-md uppercase tracking-wide">CATEGORÍA</span>
                        <span class="text-teal-600 text-sm font-bold flex items-center gap-1"><i class="fas fa-check-circle"></i> Proveedor Verificado</span>
                    </div>

                    <h2 id="p_nombre" class="text-3xl font-extrabold text-gray-900 mt-1">Nombre del Producto</h2>
                    <p id="p_desc" class="text-gray-500 mt-2 text-sm leading-relaxed whitespace-pre-line">Descripción aquí...</p>

                    <div class="mt-6 flex items-baseline gap-2">
                        <span id="p_precio" class="text-4xl font-extrabold text-teal-700">$0.00</span>
                        <span class="text-sm font-semibold text-gray-500">MXN/<span id="p_unidad">pieza</span></span>
                    </div>

                    <p class="text-sm text-gray-500 mt-2 font-medium">En Stock (<span id="p_stock">0</span> disponibles)</p>

                    <div class="bg-gray-50 rounded-xl p-5 mt-8 border border-gray-100">
                        <h3 class="font-bold text-gray-900 mb-4 text-sm">Especificaciones Rápidas</h3>
                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between border-b border-gray-200 pb-2"><span class="text-gray-500">SKU</span><span id="p_sku" class="font-bold text-gray-900">---</span></div>
                            <div class="flex justify-between border-b border-gray-200 pb-2"><span class="text-gray-500">Unidad</span><span id="p_unidad_spec" class="font-bold text-gray-900">---</span></div>
                            <div class="flex justify-between"><span class="text-gray-500">Proveedor</span><span class="font-bold text-gray-900">Tu Empresa</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Preview de imágenes antes de subir
    document.querySelector('input[type=file]').addEventListener('change', function () {
        const preview = document.getElementById('preview');
        preview.innerHTML = '';
        Array.from(this.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'w-20 h-20 object-cover rounded-lg border';
                preview.appendChild(img);
            };
            reader.readAsDataURL(file);
        });
    });

    function generarPreview() {
        // 1. Obtener valores de los inputs del formulario
        // Nota: Los IDs que genera ASP.NET suelen ser el nombre de la propiedad
        const nombre = document.getElementById('Nombre').value || "Nombre del Producto";
        const desc = document.getElementById('Descripcion').value || "Sin descripción disponible.";
        const precio = document.getElementById('PrecioUnitario').value || "0.00";
        const unidad = document.getElementById('UnidadMedida').value;
        const stock = document.getElementById('StockDisponible').value || "0";
        const sku = document.getElementById('Sku').value || "N/A";
        
        // Para la categoría obtenemos el TEXTO de la opción seleccionada, no el ID
        const catSelect = document.getElementById('CategoriaId');
        const catTexto = catSelect.options[catSelect.selectedIndex].text.replace('---', '').trim() || "General";

        // 2. Inyectar valores en el Modal
        document.getElementById('p_nombre').innerText = nombre;
        document.getElementById('p_nom_bread').innerText = nombre;
        document.getElementById('p_desc').innerText = desc;
        document.getElementById('p_precio').innerText = '$' + parseFloat(precio).toLocaleString('en-US', {minimumFractionDigits: 2});
        document.getElementById('p_unidad').innerText = unidad;
        document.getElementById('p_unidad_spec').innerText = unidad;
        document.getElementById('p_stock').innerText = stock;
        document.getElementById('p_sku').innerText = sku;
        document.getElementById('p_cat_tag').innerText = catTexto;
        document.getElementById('p_cat_bread').innerText = catTexto;

        // 3. Manejar la Imagen (usar la primera seleccionada en el input file)
        const fileInput = document.querySelector('input[type="file"]');
        if (fileInput.files && fileInput.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('p_img').src = e.target.result;
            }
            reader.readAsDataURL(fileInput.files[0]);
        } else {
            document.getElementById('p_img').src = "/Content/img/no-image.png";
        }

        // 4. Mostrar Modal
        document.getElementById('modalPreview').classList.remove('hidden');
    }

    function cerrarPreview() {
        document.getElementById('modalPreview').classList.add('hidden');
    }
</script>
