@model MediMarket.web.Models.productos
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = "Eliminar Producto";

    var imagen = Model.producto_imagenes?.FirstOrDefault(i => i.es_principal)?.url
              ?? Model.producto_imagenes?.FirstOrDefault()?.url
              ?? "/Content/img/no-image.png";
}

<div class="p-8 max-w-xl mx-auto">
    <div class="mb-6">
        <a href="@Url.Action("Index", "MiCatalogo")" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
            <i class="fas fa-arrow-left text-xs"></i> Volver al catálogo
        </a>
    </div>

    <div class="bg-white border border-red-200 rounded-xl shadow-sm overflow-hidden">

        @* Header de advertencia *@
        <div class="bg-red-50 border-b border-red-200 p-5 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                <i class="fas fa-exclamation-triangle text-red-500"></i>
            </div>
            <div>
                <h1 class="text-lg font-bold text-red-700">¿Eliminar este producto?</h1>
                <p class="text-sm text-red-500">Esta acción no se puede deshacer.</p>
            </div>
        </div>

        @* Datos del producto a eliminar *@
        <div class="p-5 flex items-center gap-4">
            <img src="@imagen" alt="@Model.nombre"
                 class="w-20 h-20 object-cover rounded-lg border shrink-0">
            <div class="space-y-1">
                <h2 class="text-xl font-bold text-gray-800">@Model.nombre</h2>
                @if (!string.IsNullOrWhiteSpace(Model.descripcion))
                {
                    <p class="text-sm text-gray-500 line-clamp-2">@Model.descripcion</p>
                }
                <div class="flex gap-4 text-sm text-gray-600 pt-1">
                    <span><span class="font-semibold">Precio:</span> $@Model.precio_unitario.ToString("N2")</span>
                    <span><span class="font-semibold">Stock:</span> @Model.stock_disponible</span>
                    @if (!string.IsNullOrWhiteSpace(Model.sku))
                    {
                        <span><span class="font-semibold">SKU:</span> @Model.sku</span>
                    }
                </div>
            </div>
        </div>

        @* Advertencia adicional si tiene imágenes *@
        @if (Model.producto_imagenes != null && Model.producto_imagenes.Any())
        {
            <div class="mx-5 mb-4 bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-700">
                <i class="fas fa-images mr-1"></i>
                Se eliminarán también <strong>@Model.producto_imagenes.Count imagen(es)</strong> asociadas al producto.
            </div>
        }

        @* Acciones *@
        <div class="p-5 border-t flex gap-3 justify-end">
            <a href="@Url.Action("Index", "MiCatalogo")"
               class="py-2 px-6 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold transition">
                Cancelar
            </a>
            @using (Html.BeginForm("Delete", "MiCatalogo", new { id = Model.id }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="py-2 px-6 rounded-lg bg-red-500 hover:bg-red-600 text-white font-bold transition">
                    <i class="fas fa-trash mr-1"></i> Sí, eliminar
                </button>
            }
        </div>
    </div>
</div>
