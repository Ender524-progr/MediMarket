@model MediMarket.web.Models.productos
@{
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
    ViewBag.Title = Model.nombre;

    var imagenPrincipal = Model.producto_imagenes?.FirstOrDefault(i => i.es_principal)?.url
                       ?? Model.producto_imagenes?.FirstOrDefault()?.url
                       ?? "/Content/img/no-image.png";

    var imagenesSecundarias = Model.producto_imagenes?
        .Where(i => !i.es_principal)
        .OrderBy(i => i.orden)
        .ToList();
}

<div class="p-8 max-w-4xl mx-auto">
    <div class="mb-6">
        <a href="@Url.Action("Index", "MiCatalogo")" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
            <i class="fas fa-arrow-left text-xs"></i> Volver al catálogo
        </a>
    </div>

    <div class="grid grid-cols-2 gap-8">

        @* Columna de imágenes *@
        <div class="space-y-3">
            <img id="imgPrincipal" src="@imagenPrincipal" alt="@Model.nombre"
                 class="w-full h-auto object-cover rounded-xl shadow-sm">

            @if (imagenesSecundarias != null && imagenesSecundarias.Any())
            {
                <div class="flex gap-2 flex-wrap">
                    <img src="@imagenPrincipal"
                         onclick="document.getElementById('imgPrincipal').src=this.src"
                         class="w-16 h-16 object-cover rounded-lg border-2 border-emerald-500 cursor-pointer">
                    @foreach (var img in imagenesSecundarias)
                    {
                        <img src="@img.url"
                             onclick="document.getElementById('imgPrincipal').src=this.src"
                             class="w-16 h-16 object-cover rounded-lg border border-gray-200 cursor-pointer hover:border-emerald-400 transition">
                    }
                </div>
            }
        </div>

        @* Columna de detalles *@
        <div class="space-y-4">
            <div class="flex items-start justify-between gap-2">
                <h1 class="text-3xl font-bold leading-tight">@Model.nombre</h1>
                <span class="shrink-0 px-3 py-1 rounded-full text-sm font-semibold @(Model.activo ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-600")">
                    @(Model.activo ? "Activo" : "Inactivo")
                </span>
            </div>

            <p class="text-3xl font-bold text-emerald-700">
                $@Model.precio_unitario.ToString("N2")
                <span class="text-base font-normal text-gray-400">/ @Model.unidad_medida</span>
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.descripcion))
            {
                <p class="text-gray-600 leading-relaxed">@Model.descripcion</p>
            }

            <div class="grid grid-cols-2 gap-3 pt-2">
                <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-xs text-gray-400 uppercase font-semibold">SKU</p>
                    <p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(Model.sku) ? "—" : Model.sku)</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-xs text-gray-400 uppercase font-semibold">Stock disponible</p>
                    <p class="font-semibold @(Model.stock_disponible > 0 ? "text-gray-800" : "text-red-500")">
                        @Model.stock_disponible unidades
                    </p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-xs text-gray-400 uppercase font-semibold">Categoría</p>
                    <p class="font-semibold text-gray-800">@(Model.categorias?.nombre ?? "—")</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-xs text-gray-400 uppercase font-semibold">Creado</p>
                    <p class="font-semibold text-gray-800">@Model.creado_en.ToString("dd/MM/yyyy")</p>
                </div>
            </div>

            @* Acciones *@
            <div class="flex gap-3 pt-4 border-t">
                <a href="@Url.Action("Edit", "MiCatalogo", new { id = Model.id })"
                   class="flex-1 text-center py-2 px-4 rounded-lg bg-teal-700 hover:bg-teal-800 text-white font-bold transition">
                    <i class="fas fa-edit mr-1"></i> Editar
                </a>
                <a href="@Url.Action("Delete", "MiCatalogo", new { id = Model.id })"
                   class="flex-1 text-center py-2 px-4 rounded-lg bg-red-500 hover:bg-red-600 text-white font-bold transition">
                    <i class="fas fa-trash mr-1"></i> Eliminar
                </a>
            </div>
        </div>
    </div>
</div>
