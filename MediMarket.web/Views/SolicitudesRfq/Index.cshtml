@model IEnumerable<MediMarket.web.Models.solicitudes_rfq>
@{
    ViewBag.Title = "Mis Solicitudes (RFQ)";
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
}

@* ── Toast de éxito ─────────────────────────────────────────────────────── *@
@if (TempData["Exito"] != null)
{
    <div id="toast"
         class="fixed top-6 right-6 z-50 flex items-center gap-3
                bg-teal-700 text-white px-5 py-3 rounded-xl shadow-lg
                animate-fade-in">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Exito"]</span>
    </div>
    <script>setTimeout(() => document.getElementById('toast')?.remove(), 3500);</script>
}

<div class="p-8">

    @* ── Encabezado ─────────────────────────────────────────────────────────── *@
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Solicitudes (RFQ)</h1>
            <p class="text-sm text-gray-500 mt-1">Gestiona tus requerimientos de suministros medicos.</p>
        </div>
        <a href="@Url.Action("Crear")"
           class="flex items-center gap-2 bg-teal-700 hover:bg-teal-800
                  text-white text-sm font-semibold px-5 py-2.5 rounded-xl
                  transition-colors shadow-md shadow-teal-100">
            <i class="fa-solid fa-plus"></i>
            Nueva solicitud
        </a>
    </div>

    @* ── Filtros ─────────────────────────────────────────────────────────────── *@
    @using (Html.BeginForm("Index", "SolicitudesRfq", FormMethod.Get,
            new { @class = "flex flex-wrap gap-3 mb-8" }))
    {
        <div class="flex-1 min-w-70 relative">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" name="buscar" value="@ViewBag.Buscar"
                   placeholder="Buscar por titulo..."
                   class="w-full pl-11 pr-4 py-2.5 rounded-xl border border-gray-200 bg-white
                          text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-800 transition-all" />
        </div>

        <select name="estado"
                class="px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm
                       focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-800 transition-all">
            <option value="">Todos los estados</option>
            <option value="abierta" @(ViewBag.EstadoFiltro == "abierta" ? "selected" : "")>Abierta</option>
            <option value="en_revision" @(ViewBag.EstadoFiltro == "en_revision" ? "selected" : "")>En revision</option>
            <option value="cerrada" @(ViewBag.EstadoFiltro == "cerrada" ? "selected" : "")>Cerrada</option>
            <option value="cancelada" @(ViewBag.EstadoFiltro == "cancelada" ? "selected" : "")>Cancelada</option>
        </select>

        <button type="submit"
                class="px-6 py-2.5 rounded-xl bg-gray-800 hover:bg-gray-900
                       text-white text-sm font-semibold transition-colors">
            Filtrar
        </button>

        @* Quitamos la @ del if porque ya estamos dentro del bloque 'using' *@
        if (!string.IsNullOrEmpty((string)ViewBag.EstadoFiltro) || !string.IsNullOrEmpty((string)ViewBag.Buscar))
        {
            <text>
                <a href="@Url.Action("Index")"
                   class="px-4 py-2.5 rounded-xl border border-gray-300 hover:bg-gray-100
                          text-sm text-gray-600 transition-colors flex items-center gap-2">
                    <i class="fa-solid fa-xmark"></i> Limpiar
                </a>
            </text>
        }
    } @* Aquí cierra el BeginForm *@

    @* ── Renderizado de Solicitudes ────────────────────────────────────────── *@
    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center
                    bg-white rounded-3xl border border-dashed border-gray-200 py-24 text-gray-400">
            <div class="size-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                <i class="fa-solid fa-file-circle-question text-3xl text-gray-200"></i>
            </div>
            <p class="text-lg font-medium text-gray-600">Sin solicitudes encontradas</p>
            <p class="text-sm mt-1">Crea tu primera RFQ para empezar a recibir ofertas.</p>
            <a href="@Url.Action("Crear")"
               class="mt-6 bg-teal-700 hover:bg-teal-800 text-white
                      text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">
                + Nueva solicitud
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4">
            @foreach (var rfq in Model)
            {
                @* Lógica de estilos por estado *@
                string badgeClass, dotClass, iconClass;
                switch (rfq.estado)
                {
                    case "abierta":
                        badgeClass = "bg-teal-50 text-teal-800 border-teal-100";
                        dotClass = "bg-teal-500";
                        iconClass = "fa-briefcase-medical";
                        break;
                    case "en_revision":
                        badgeClass = "bg-blue-50 text-blue-700 border-blue-100";
                        dotClass = "bg-blue-500";
                        iconClass = "fa-clock";
                        break;
                    case "cerrada":
                        badgeClass = "bg-gray-50 text-gray-600 border-gray-100";
                        dotClass = "bg-gray-400";
                        iconClass = "fa-lock";
                        break;
                    default: // cancelada
                        badgeClass = "bg-red-50 text-red-600 border-red-100";
                        dotClass = "bg-red-500";
                        iconClass = "fa-ban";
                        break;
                }

                <div class="group bg-white rounded-2xl border border-gray-200 p-5 shadow-lg hover:shadow-md hover:border-teal-800 transition-all flex flex-col md:flex-row items-center justify-between gap-6">
                    
                    @* Izquierda: Icono y Título *@
                    <div class="flex items-center gap-5 flex-1 w-full">
                        <div class="size-14 rounded-2xl bg-gray-50 flex items-center justify-center text-teal-700 text-xl group-hover:animate-pulse group-hover:bg-teal-50 transition-colors">
                            <i class="fa-solid @iconClass"></i>
                        </div>
                        <div>
                            <div class="flex items-center gap-3 mb-1">
                                <h3 class="font-bold text-gray-800 text-lg">@rfq.titulo</h3>
                                <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border @badgeClass flex items-center gap-1.5">
                                    <span class="size-1.5 rounded-full @dotClass animate-pulse"></span>
                                    @(rfq.estado == "en_revision" ? "En revision" : rfq.estado)
                                </span>
                            </div>
                            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-400">
                                <span class="flex items-center gap-1.5">
                                    <i class="fa-solid fa-layer-group text-[12px]"></i>
                                    @(rfq.categorias?.nombre ?? "Sin categoria")
                                </span>
                                <span class="flex items-center gap-1.5">
                                    <i class="fa-solid fa-calendar-day text-[12px]"></i>
                                    Limite: @(rfq.fecha_limite.HasValue ? rfq.fecha_limite.Value.ToString("dd MMM") : "N/A")
                                </span>
                                @if (!string.IsNullOrEmpty(rfq.cantidad_estimada))
                                {
                                    <span class="flex items-center gap-1.5">
                                        <i class="fa-solid fa-boxes-stacked text-[12px]"></i>
                                        @rfq.cantidad_estimada
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    @* Derecha: Acciones *@
                    <div class="flex items-center gap-3 w-full md:w-auto justify-end">
                        <a href="@Url.Action("Editar", new { id = rfq.id })" 
                           class="p-2.5 rounded-xl text-gray-400 hover:text-teal-700 hover:bg-teal-50 transition-all" 
                           title="Editar">
                            <i class="fa-solid fa-pen-to-square text-lg"></i>
                        </a>
                        
                        <button onclick="abrirModalEliminar('@rfq.id', '@Html.Raw(rfq.titulo.Replace("'","\\\'"))')"
                                class="p-2.5 rounded-xl text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all"
                                title="Eliminar">
                            <i class="fa-solid fa-trash-can text-lg"></i>
                        </button>

                        @* Botón principal hacia Detalles *@
                        <a href="@Url.Action("Detalles", new { id = rfq.id })" 
                           class="ml-2 px-6 py-2.5 bg-gray-50 hover:bg-gray-100 text-gray-700 font-semibold text-sm rounded-xl transition-all border border-gray-200">
                            Ver detalle
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── Modal de confirmación de eliminación ─────────────────────────────────── *@
<div id="modalEliminar"
     class="hidden fixed inset-0 z-50 flex items-center justify-center
            bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-sm w-full mx-4 animate-scale-in">
        <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-4">
                 <i class="fa-solid fa-triangle-exclamation text-red-500 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Eliminar la solicitud</h3>
            <p id="modalTitulo" class="text-sm text-gray-500 mb-6 px-4"></p>

            @using (Html.BeginForm("Eliminar", "SolicitudesRfq", FormMethod.Post,
                   new { id = "formEliminar", @class = "w-full" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" id="inputIdEliminar" name="id" />
                <div class="flex gap-3">
                    <button type="button" onclick="cerrarModalEliminar()"
                            class="flex-1 px-4 py-3 rounded-xl border border-gray-300
                                   hover:bg-gray-50 text-sm font-semibold text-gray-700 transition-colors">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="flex-1 px-4 py-3 rounded-xl bg-red-500 hover:bg-red-600
                                   text-white text-sm font-semibold transition-colors shadow-lg shadow-red-100">
                        Si, eliminar
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function abrirModalEliminar(id, titulo) {
        document.getElementById('inputIdEliminar').value = id;
        document.getElementById('modalTitulo').textContent = '"' + titulo + '"';
        document.getElementById('modalEliminar').classList.remove('hidden');
    }
    function cerrarModalEliminar() {
        document.getElementById('modalEliminar').classList.add('hidden');
    }
    // Cerrar con Escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') cerrarModalEliminar();
    });
</script>