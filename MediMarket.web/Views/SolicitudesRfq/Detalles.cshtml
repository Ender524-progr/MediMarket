@model MediMarket.web.Models.solicitudes_rfq
@{
    ViewBag.Title = "Detalles de Solicitud";
    Layout = "~/Views/Shared/_LayoutProveedores.cshtml";
}

<div class="p-8 max-w-5xl mx-auto">
    @* Cabecera con Título y Botón Editar *@
    <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">@Model.titulo</h1>
            <p class="text-gray-400 mt-1 flex items-center gap-2">
                <i class="fa-solid fa-calendar-alt"></i>
                Fecha límite: @(Model.fecha_limite.HasValue ? Model.fecha_limite.Value.ToString("dd MMMM, yyyy") : "Sin límite")
            </p>
        </div>
        <a href="@Url.Action("Editar", new { id = Model.id })" class="flex items-center gap-2 text-teal-600 font-bold hover:bg-teal-50 px-4 py-2 rounded-xl transition-all">
            <i class="fa-solid fa-pen"></i> Editar
        </a>
    </div>

    @* Info Cards (Categoría, Cantidad, Presupuesto) *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Categoría</p>
            <p class="text-gray-800 font-bold">@(Model.categorias?.nombre ?? "N/A")</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Cantidad</p>
            <p class="text-gray-800 font-bold">@(Model.cantidad_estimada ?? "No especificada")</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Estado</p>
            <span class="inline-block px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold uppercase">@Model.estado</span>
        </div>
    </div>

    @* Descripción Detallada *@
    <div class="mb-12">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Descripción detallada</h2>
        <div class="bg-gray-50 p-6 rounded-2xl text-gray-600 leading-relaxed border border-dashed border-gray-200">
            @Model.descripcion
        </div>
    </div>

    @* Listado de Cotizaciones Recibidas *@
    <div>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-800">Cotizaciones recibidas (@Model.cotizaciones.Count)</h2>
        </div>

        @if (!Model.cotizaciones.Any())
        {
            <div class="text-center py-12 bg-white rounded-3xl border border-dashed border-gray-200">
                <i class="fa-solid fa-hourglass-half text-4xl text-gray-200 mb-3"></i>
                <p class="text-gray-400">Aún no has recibido ofertas para esta solicitud.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach (var cot in Model.cotizaciones.OrderBy(c => c.monto))
                {
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex items-center gap-3">
                                <img src="@cot.proveedores.usuarios.foto_url" class="size-10 rounded-full object-cover bg-gray-100" />
                                <div>
                                    <p class="font-bold text-gray-800">@cot.proveedores.nombre_empresa</p>
                                    <p class="text-[10px] text-green-600 font-bold uppercase tracking-wider">Verificado</p>
                                </div>
                            </div>
                            <p class="text-xl font-black text-gray-800">@cot.monto.ToString("C")</p>
                        </div>
                        <p class="text-xs text-gray-500 mb-4 italic">"@cot.notas"</p>
                        <div class="flex gap-2">
                            <button class="flex-1 py-2.5 bg-teal-800 text-white rounded-xl font-bold text-sm hover:bg-teal-900 transition-colors">Aceptar</button>
                            <button class="px-4 py-2.5 bg-gray-100 text-gray-400 rounded-xl hover:bg-gray-200 transition-colors">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>