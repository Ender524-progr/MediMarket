@model MediMarket.web.Models.solicitudes_rfq
@{
    ViewBag.Title = "Detalles de Solicitud";
     Layout = "~/Views/Shared/_LayoutShop.cshtml";
}
<div class="pt-16">
<div class="p-8 md:max-w-7xl mx-auto">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
        <a href="@Url.Action("Index")" class="hover:text-gray-700 transition-colors">
            Solicitudes
        </a>
        <i class="fa-solid fa-chevron-right text-xs"></i>
        <span class="text-gray-700 font-medium">Detalles de solicitud</span>
    </nav>

<div class="p-8 max-w-5xl mx-auto">
    @* Cabecera con Título y Botón Editar *@
    <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">@Model.titulo</h1>
            <p class="text-gray-400 mt-1 flex items-center gap-2">
                <i class="fa-solid fa-calendar-alt"></i>
                Fecha límite: @(Model.fecha_limite.HasValue ? Model.fecha_limite.Value.ToString("dd MMMM, yyyy") : "Sin límite")
            </p>
        </div>
        <div class="flex gap-2">
    <a href="@Url.Action("Editar", new { id = Model.id })" class="px-4 py-2 rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-200 font-semibold text-sm transition-all">
        <i class="fa-solid fa-pen mr-1"></i> Editar solicitud
    </a>

    @using (Html.BeginForm("CambiarEstado", "SolicitudesRfq", FormMethod.Post, new { @class = "inline" }))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("id", Model.id)

        if (Model.estado == "abierta" || Model.estado == "en_revision")
        {
            <input type="hidden" name="nuevoEstado" value="cerrada" />
            <button type="submit" class="px-4 py-2 rounded-xl bg-red-700 text-white hover:bg-red-800 font-semibold text-sm transition-all shadow-sm">
                <i class="fa-solid fa-lock mr-1"></i> Cerrar solicitud
            </button>
        }
        else if (Model.estado == "cerrada" || Model.estado == "cancelada")
        {
            <input type="hidden" name="nuevoEstado" value="abierta" />
            <button type="submit" class="px-4 py-2 rounded-xl bg-teal-600 text-white hover:bg-teal-700 font-semibold text-sm transition-all shadow-sm">
                <i class="fa-solid fa-rotate-left mr-1"></i> Volver a abrir
            </button>
        }
    }
</div>
    </div>

    @* Info Cards (Categoría, Cantidad, Presupuesto) *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Categoría</p>
            <p class="text-gray-800 font-bold">@(Model.categorias?.nombre ?? "N/A")</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Cantidad</p>
            <p class="text-gray-800 font-bold">@(Model.cantidad_estimada ?? "No especificada")</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Estado</p>
            <span class="inline-block px-3 py-1 bg-green-100 text-teal-800 rounded-full text-xs font-bold uppercase">@Model.estado</span>
        </div>
    </div>

    @* Descripción Detallada *@
    <div class="mb-12">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Descripción detallada</h2>
        <div class="bg-gray-50 p-6 rounded-2xl text-gray-600 leading-relaxed border border-dashed border-gray-200">
            @Model.descripcion
        </div>
    </div>

    @* Listado de Cotizaciones Recibidas *@
    <div>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-800">Cotizaciones recibidas (@Model.cotizaciones.Count)</h2>
        </div>

        @if (!Model.cotizaciones.Any())
        {
            <div class="text-center py-12 bg-white rounded-3xl border border-dashed border-gray-200">
                <i class="fa-solid fa-hourglass-half text-4xl text-gray-200 mb-3"></i>
                <p class="text-gray-400">Aún no has recibido ofertas para esta solicitud.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach (var cot in Model.cotizaciones.OrderBy(c => c.monto))
                {
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex items-center gap-3">
                                @* Le puse el ? por seguridad para que no truene si no hay foto *@
                                <img src="@(cot.proveedores?.usuarios?.foto_url ?? "/Content/img/no-image.png")" class="size-10 rounded-full object-cover bg-gray-100" />
                                <div>
                                    <p class="font-bold text-gray-800">@cot.proveedores.nombre_empresa</p>
                                    @if (cot.proveedores.usuarios != null && cot.proveedores.usuarios.estado_verificacion == "verificado")
{
    <p class="text-[10px] text-green-600 font-bold uppercase tracking-wider flex items-center gap-1">
        <i class="fas fa-shield-check"></i> Verificado
    </p>
}   
                                </div>
                            </div>
                            <p class="text-xl font-black text-gray-800">@cot.monto.ToString("C")</p>
                        </div>
                        
                        <p class="text-xs text-gray-500 mb-4 italic line-clamp-2">"@cot.notas"</p>
                        
                        @* Botones de Acción *@
                        <div class="flex gap-2 mt-auto">
                            @if (Model.estado == "abierta" && cot.estado != "rechazada")
                            {
                                using (Html.BeginForm("AceptarCotizacion", "SolicitudesRfq", FormMethod.Post, new { @class = "flex-1" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cotizacionId" value="@cot.id" />
                                    <input type="hidden" name="rfqId" value="@Model.id" />
                                    <button type="submit" class="w-full py-2.5 bg-teal-800 text-white rounded-xl font-bold text-sm hover:bg-teal-900 transition-colors">
                                        Aceptar
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="flex-1 text-center py-2.5 rounded-xl bg-gray-50 border border-gray-200">
                                    <span class="text-xs font-bold uppercase tracking-wider @(cot.estado == "aceptada" ? "text-emerald-600" : cot.estado == "rechazada" ? "text-red-500" : "text-gray-400")">
                                        @cot.estado
                                    </span>
                                </div>
                            }

                            <button type="button" onclick="abrirModalCotizacion('@cot.id')" class="px-4 py-2.5 bg-gray-100 text-gray-500 rounded-xl hover:bg-gray-200 transition-colors">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    @* ── MODAL FLOTANTE (Oculto) para Ver Detalles ── *@
                    <div id="modal_@cot.id" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-gray-900/60 backdrop-blur-sm transition-opacity">
                        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4 overflow-hidden transform scale-95 transition-transform duration-200" id="modalContent_@cot.id">
                            
                            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                                <h3 class="font-bold text-gray-800">Detalles de la Oferta</h3>
                                <button type="button" onclick="cerrarModalCotizacion('@cot.id')" class="text-gray-400 hover:text-red-500 transition-colors">
                                    <i class="fa-solid fa-xmark text-lg"></i>
                                </button>
                            </div>

                            <div class="p-6 space-y-4">
                                <div class="flex justify-between items-center border-b border-gray-100 pb-3">
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Proveedor</span>
                                    <span class="font-semibold text-gray-800">@cot.proveedores.nombre_empresa</span>
                                </div>
                                <div class="flex justify-between items-center border-b border-gray-100 pb-3">
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Monto</span>
                                    <span class="text-lg font-black text-teal-800">@cot.monto.ToString("C")</span>
                                </div>
                                <div class="flex justify-between items-center border-b border-gray-100 pb-3">
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Tiempo de Entrega</span>
                                    <span class="font-medium text-gray-600">@(string.IsNullOrEmpty(cot.tiempo_entrega) ? "No especificado" : cot.tiempo_entrega)</span>
                                </div>
                                <div class="pt-2">
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest block mb-2">Notas del proveedor</span>
                                    <p class="text-sm text-gray-600 bg-gray-50 p-4 rounded-2xl border border-gray-100 leading-relaxed italic">
                                        @(string.IsNullOrEmpty(cot.notas) ? "Sin notas adicionales." : cot.notas)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function abrirModalCotizacion(id) {
        const modal = document.getElementById('modal_' + id);
        const content = document.getElementById('modalContent_' + id);
        if(modal) {
            modal.classList.remove('hidden');
            setTimeout(() => content.classList.remove('scale-95'), 10);
            document.body.style.overflow = 'hidden';
        }
    }

    function cerrarModalCotizacion(id) {
        const modal = document.getElementById('modal_' + id);
        const content = document.getElementById('modalContent_' + id);
        if(modal) {
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 200);
        }
    }

    // Cerrar al dar clic afuera del cuadrito blanco
    document.addEventListener('click', function(e) {
        if (e.target.id && e.target.id.startsWith('modal_')) {
            cerrarModalCotizacion(e.target.id.split('_')[1]);
        }
    });
</script>