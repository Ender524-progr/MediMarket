@model IEnumerable<MediMarket.web.Models.lista_deseos>
@{
    Layout = "~/Views/Shared/_LayoutShop.cshtml";
    ViewBag.Title = "Mi Lista de Deseos";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 pt-24 bg-gray-50 min-h-screen">

<a href="@Url.Action("Index", "Shop")" class="inline-flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-teal-600 transition-colors mb-6 group">
        <i class="fa-solid fa-arrow-left-long group-hover:-translate-x-1 transition-transform"></i> Seguir comprando
    </a>
    
    <div class="mb-8 flex items-baseline gap-3">
        <h1 class="text-3xl font-bold text-gray-900">
            <i class="fa-solid fa-heart text-pink-500 mr-2"></i>Lista de Deseos
        </h1>
        <span class="text-gray-500 font-medium">(@Model.Count() artículos)</span>
    </div>

    <div class="space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-12 text-center mt-10">
                <div class="w-20 h-20 bg-pink-50 rounded-full flex items-center justify-center mx-auto mb-4 text-pink-300 text-3xl">
                    <i class="fa-regular fa-heart"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Tu lista está vacía</h3>
                <p class="text-sm text-gray-500 mb-6">Guarda aquí los equipos e insumos que quieras comprar después.</p>
                <a href="@Url.Action("Index", "Shop")" class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2.5 px-6 rounded-xl transition">
                    Explorar productos
                </a>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                var producto = item.productos;
                var img = producto.producto_imagenes?.FirstOrDefault(i => i.es_principal)?.url
                          ?? producto.producto_imagenes?.FirstOrDefault()?.url
                          ?? "/Content/img/no-image.png";

                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-200 flex flex-col sm:flex-row gap-5 items-center transition-all hover:shadow-md">

                    @* Imagen clickable *@
                    <div class="w-28 h-28 shrink-0 bg-gray-100 rounded-xl overflow-hidden border border-gray-100">
                        <a href="@Url.Action("Details", "Shop", new { id = producto.id })">
                            <img src="@img" class="w-full h-full object-cover hover:scale-105 transition-transform" />
                        </a>
                    </div>

                    @* Info y Botones *@
                    <div class="flex-1 w-full">
                        <div class="flex flex-col sm:flex-row justify-between items-start gap-2">
                            <div>
                                <a href="@Url.Action("Details", "Shop", new { id = producto.id })" class="font-bold text-gray-900 text-lg hover:text-teal-600 transition-colors">
                                    @producto.nombre
                                </a>
                                <p class="text-xs text-gray-500 mt-1"><i class="fa-solid fa-store mr-1 text-gray-400"></i> @(producto.proveedores?.nombre_empresa)</p>
                                <p class="text-[10px] text-gray-400 mt-1">Agregado el @item.fecha_agregado.ToString("dd/MMM/yyyy")</p>
                            </div>
                            <span class="text-xl font-bold text-teal-700 shrink-0">$@producto.precio_unitario.ToString("N2")</span>
                        </div>

                        <div class="flex justify-end items-center mt-4 gap-3">
                            @* Eliminar *@
                            @using (Html.BeginForm("Eliminar", "ListaDeseos", FormMethod.Post))
                            {
                                <input type="hidden" name="id" value="@item.id" />
                                <button type="submit" class="text-sm font-semibold text-gray-500 hover:text-red-500 transition-colors px-3 py-2 rounded-lg border border-transparent hover:border-red-100 hover:bg-red-50">
                                    <i class="fa-solid fa-trash-can mr-1"></i> Eliminar
                                </button>
                            }

                            @* Añadir al Carrito (Reutiliza tu JS) *@
                            <button onclick="agregarAlCarrito('@producto.id')"
                                    class="text-sm font-semibold text-white bg-teal-600 hover:bg-teal-700 transition-colors px-4 py-2 rounded-xl shadow-sm flex items-center gap-2"
                                    @(producto.stock_disponible == 0 ? "disabled" : "")>
                                <i class="fa-solid fa-cart-plus"></i> @(producto.stock_disponible == 0 ? "Agotado" : "Añadir al carrito")
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>