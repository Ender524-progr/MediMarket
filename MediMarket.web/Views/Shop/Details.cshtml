@model MediMarket.web.Models.productos
@{
Layout = "~/Views/Shared/_LayoutShop.cshtml";
ViewBag.Title = "Details";


var imagenes = Model.producto_imagenes?.OrderBy(i => i.orden).ToList() ?? new List
<MediMarket.web.Models.producto_imagenes>();
    var imgPrincipal = imagenes.FirstOrDefault(i => i.es_principal)?.url ?? imagenes.FirstOrDefault()?.url ??
    "/Content/img/no-image.png";

    var comentarios = Model.producto_comentarios?.OrderByDescending(c => c.creado_en).ToList() ?? new List
    <MediMarket.web.Models.producto_comentarios>();
        var promedio = comentarios.Any() ? Math.Round(comentarios.Average(c => c.calificacion), 1) : 0.0;

        Guid? miClinicaId = ViewBag.MiClinicaId as Guid?;
        var miComentario = comentarios.FirstOrDefault(c => c.clinica_id == miClinicaId);
        }

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-24">

            @* ── Breadcrumbs ── *@
            <nav class="text-sm text-gray-500 mb-8">
                <a href="@Url.Action("Index", "Shop" )" class="hover:text-teal-600">Marketplace</a>
                <span class="mx-2">›</span>
                <span>@(Model.categorias?.nombre ?? "General")</span>
                <span class="mx-2">›</span>
                <span class="text-gray-800 font-semibold">@Model.nombre</span>
            </nav>

            @* ── BLOQUE PRINCIPAL: Galería e Info ── *@
            <div class="flex flex-col lg:flex-row gap-12 mb-16">

                @* Izquierda: Galería de Imágenes *@
                <div class="lg:w-4/6">
                    <div
                        class="bg-gray-100 rounded-2xl overflow-hidden mb-4 border-2 border-gray-300/50 h-[500px] flex items-center justify-center">
                        <img id="mainImage" src="@imgPrincipal" alt="@Model.nombre" class="w-full h-full object-cover">
                    </div>

                    @* Miniaturas *@
                    @if (imagenes.Count > 1)
                    {
                    <div class="flex gap-4 overflow-x-auto pb-2">
                        @foreach (var img in imagenes)
                        {
                        <button onclick="document.getElementById('mainImage').src='@img.url'"
                            class="w-24 h-24 shrink-0 rounded-xl border-2 border-transparent hover:border-gray-300 focus:border-gray-300 overflow-hidden bg-gray-100 transition-all">
                            <img src="@img.url" class="w-full h-full object-cover">
                        </button>
                        }
                    </div>
                    }
                </div>

                @* Derecha: Detalles del Producto y Compra *@
                <div class="lg:w-2/6 flex flex-col">
                    <div class="flex items-center gap-3 mb-2">
                        <span
                            class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold uppercase tracking-wider rounded-md">
                            @(Model.categorias?.nombre ?? "Médico")
                        </span>
                        <span class="text-teal-600 text-sm font-semibold flex items-center gap-1">
                            <i class="fa-solid fa-circle-check"></i> Proveedor Verificado
                        </span>
                    </div>

                    <h1 class="text-3xl font-bold text-gray-900 mb-4">@Model.nombre</h1>

                    <p class="text-gray-600 mb-6 leading-relaxed text-sm ml-1">
                        @Model.descripcion
                    </p>

                    <div class="flex items-end gap-3 mb-6">
                        <span class="text-3xl font-black text-teal-700">$@Model.precio_unitario.ToString("N2")</span>
                        <span class="text-gray-700 font-bold text-sm pb-1">MXN/@Model.unidad_medida</span>
                    </div>

                    @* Stock Status *@
                    <div class="mb-8 flex items-center gap-2 text-sm font-semibold @(Model.stock_disponible > 0 ? "text-gray-400" : "text-red-500" )">

                        @(Model.stock_disponible > 0 ? $"En Stock ({Model.stock_disponible} disponibles)" : "Agotado por el momento")
                    </div>
                    @* Botones de Acción *@
                    <button class="w-full py-3 rounded-xl mb-3  gap-2
                    bg-teal-700 hover:bg-teal-800 text-white 
                    font-bold 
                    transition-colors shadow-md 
                    flex justify-center items-center" @(Model.stock_disponible==0 ? "disabled" : "" )
                        onclick="agregarAlCarrito('@Model.id');">
                        <i class="fas fa-shopping-cart"></i> Agregar al Carrito
                    </button>

                    @{
                    bool enDeseos = ViewBag.EnListaDeseos != null && (bool)ViewBag.EnListaDeseos;
                    string btnClass = enDeseos ? "bg-pink-100 text-pink-700 hover:bg-pink-200" : "bg-gray-200 text-gray-800 hover:bg-red-50 hover:text-red-600";
                    string iconClass = enDeseos ? "fa-solid scale-110" : "fa-regular";
                    string textoBtn = enDeseos ? "Agregado a lista de deseos" : "Agregar a lista de deseos";
                    }

                    <button id="btnDeseos_@Model.id" onclick="toggleListaDeseos('@Model.id')"
                        class="w-full py-3 font-bold rounded-xl transition-all duration-200 flex justify-center items-center gap-2 @btnClass">
                        <i id="iconDeseos_@Model.id" class="@iconClass fa-heart text-lg transition-transform"></i>
                        <span id="textDeseos_@Model.id">@textoBtn</span>
                    </button>




                    @* Specs Rápidas (Opcional, basado en tu diseño) *@
                    <div class="mt-8 bg-gray-50 rounded-xl p-6 border-2 border-gray-300/70">
                        <h3 class="font-bold text-gray-800 mb-4">Especificaciones Rápidas</h3>
                        <ul class="text-sm text-gray-600 space-y-3">
                            <li class="flex justify-between border-b border-gray-300 pb-2"><span>SKU</span> <span
                                    class="font-semibold text-gray-900">@Model.sku</span></li>
                            <li class="flex justify-between border-b border-gray-300 pb-2"><span>Unidad</span> <span
                                    class="font-semibold text-gray-900">@Model.unidad_medida</span></li>
                            <li class="flex justify-between"><span>Proveedor</span> <span
                                    class="font-semibold text-gray-900">@(Model.proveedores?.nombre_empresa)</span></li>
                        </ul>
                    </div>
                </div>
            </div>

            @* ── BLOQUE INFERIOR: Specs Técnicas y Comentarios ── *@
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

                @* Especificaciones Técnicas (Izquierda, toma 2 columnas) *@
                <div class="lg:col-span-2">
                    <h2 class="text-2xl font-bold text-gray-900 mb-6">Información Detallada</h2>
                    <div class="prose max-w-none text-gray-600">
                        <p>Mas detalles de los productos, funcionalidades y características proximamente disponibles.</p>
                    </div>
                </div>

                @* Comentarios (Derecha, toma 1 columna) *@
                <div class="bg-gray-50 p-6 rounded-2xl shadow-sm shadow-gray-400 h-fit">
                    <h2 class="text-xl font-bold text-gray-900 mb-6 flex justify-between items-center">
                        Opiniones de Clínicas
                        @if(comentarios.Any())
                        {
                        <span class="text-sm font-normal text-gray-500">@promedio.ToString("0.0") <i
                                class="fa-solid fa-star text-yellow-400"></i> (@comentarios.Count)</span>
                        }
                        else
                        {
                        <span class="text-sm font-normal text-gray-400">Sin reseñas</span>
                        }
                    </h2>

                    @* Mostrar solo los primeros 2 comentarios en la vista principal *@
                    @foreach (var com in comentarios.Take(2))
                    {
                    <div class="mb-5 pb-5 border-b border-gray-400">
                        <div class="flex items-center gap-3 mb-2">
                            <div
                                class="w-8 h-8 rounded-full bg-teal-600 text-white flex items-center justify-center font-bold text-xs uppercase">
                                @(com.clinicas.nombre_clinica.Substring(0,1))
                            </div>
                            <div>
                                <p class="text-sm font-bold text-gray-800">@com.clinicas.nombre_clinica</p>
                                <p class="text-[10px] text-gray-400">@com.creado_en.ToString("dd MMM yyyy")</p>
                            </div>
                        </div>
                        <div class="flex text-yellow-400 text-[10px] mb-1">
                            @for (int i = 0; i < com.calificacion; i++) { <i class="fa-solid fa-star"></i> }
                        </div>
                        <p class="text-sm text-gray-600 line-clamp-3">@com.comentario</p>
                    </div>
                    }

                    @* Botón Ver Todos (solo si hay más de 0) *@
                    @if(comentarios.Any())
                    {
                    <button onclick="document.getElementById('modalComentarios').classList.remove('hidden')"
                        class="w-full py-2.5 border border-teal-600 text-teal-700 font-semibold rounded-xl text-sm hover:bg-teal-50 transition-colors mb-6">
                        Ver todas las opiniones
                    </button>
                    }

                    @* ── FORMULARIO: Tu opinión ── *@
                    <div class="bg-gray-50 p-5 rounded-xl ">
                        <h4 class="text-sm font-bold text-gray-800 mb-3">@(miComentario != null ? "Editar tu opinión" :
                            "Tu opinión")</h4>

                        @using (Html.BeginForm("GuardarComentario", "Shop", FormMethod.Post))
                        {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="producto_id" value="@Model.id" />

                        int calActual = miComentario != null ? miComentario.calificacion : 5;

                        <input type="hidden" name="calificacion" id="inputCalificacion" value="@calActual" />

                        <div class="flex items-center gap-3 mb-4">

                            <div class="flex text-base cursor-pointer" id="contenedorEstrellas">
                                @for (int i = 1; i <= 5; i++) { <i class="fa-star transition-all duration-200 hover:scale-110
                                     @(i <= calActual ? " fa-solid text-yellow-400" : "fa-regular text-gray-300" )"
                                    onclick="marcarEstrellas(@i)"></i>
                                    }
                            </div>
                            <!-- Texto dinámico -->
                            <span id="textoCalificacion" class="text-sm font-bold text-gray-600"></span>
                        </div>

                        <textarea name="comentario" required rows="3" placeholder="¿Qué te pareció el producto?"
                            class="w-full p-3 border border-gray-400 rounded-lg text-sm mb-3 focus:ring-2 focus:ring-teal-500 outline-none resize-none">@(miComentario?.comentario)</textarea>

                        <button type="submit"
                            class="w-full py-2 bg-gray-800 hover:bg-gray-900 text-white font-semibold rounded-lg text-sm transition-colors">
                            @(miComentario != null ? "Actualizar" : "Publicar reseña")
                        </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ──────────────── MODAL DE COMENTARIOS ──────────────── *@
        <div id="modalComentarios"
            class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900/50 backdrop-blur-sm transition-opacity">
            <div
                class="bg-white rounded-2xl shadow-2xl shadow-gray-400 w-full max-w-2xl mx-4 max-h-[85vh] flex flex-col overflow-hidden">

                <div class="flex justify-between items-center p-6 border-b border-gray-100">
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Calificaciones y opiniones</h3>
                        <p class="text-sm text-gray-500">@Model.nombre</p>
                    </div>
                    <button type="button" onclick="document.getElementById('modalComentarios').classList.add('hidden')"
                        class="text-gray-400 hover:text-red-500 text-2xl transition-colors">
                        &times;
                    </button>
                </div>

                <div class="p-6 overflow-y-auto space-y-6 flex-1 bg-gray-50">
                    @* Aquí se imprimen TODOS los comentarios de la BD *@
                    @foreach(var com in comentarios)
                    {
                    <div class="bg-white p-5 rounded-xl border-2 border-gray-300/70">
                        <div class="flex justify-between items-start mb-3">
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold uppercase">
                                    @(com.clinicas.nombre_clinica.Substring(0,1))
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-gray-800">@com.clinicas.nombre_clinica</p>
                                    <div class="flex text-yellow-400 text-xs mt-0.5">
                                        @for (int i = 0; i < com.calificacion; i++) { <i class="fa-solid fa-star"></i> }
                                    </div>
                                </div>
                            </div>
                            <span class="text-xs text-gray-400">@com.creado_en.ToString("dd MMM yyyy")</span>
                        </div>
                        <p class="text-sm text-gray-600 leading-relaxed">
                            @com.comentario
                        </p>
                    </div>
                    }
                </div>
            </div>
        </div>

        <script>
            function agregarAlCarrito(productoId) {
                // Placeholder — conectar con CarritoController cuando esté listo
                fetch('/Carrito/Agregar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value },
                    body: JSON.stringify({ productoId: productoId, cantidad: 1 })
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.ok) {
                            mostrarToast('Producto agregado al carrito', 'success');
                            actualizarContadorCarrito(data.contador); // <--- Llama a la función del Layout
                        }
                        else mostrarToast(data.mensaje || 'Error al agregar', 'error');
                    })
                    .catch(() => mostrarToast('No se pudo conectar', 'error'));
            }

            function toggleListaDeseos(productoId) {
                fetch('/ListaDeseos/Toggle?productoId=' + productoId, { method: 'POST' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.ok) {
                            const btn = document.getElementById('btnDeseos_' + productoId);
                            const icono = document.getElementById('iconDeseos_' + productoId);
                            const texto = document.getElementById('textDeseos_' + productoId);

                            if (btn && icono && texto) {
                                if (data.agregado) {
                                    // MODO ROSA (Agregado)
                                    btn.className = "w-full py-3 font-bold rounded-xl transition-all duration-200 flex justify-center items-center gap-2 bg-pink-100 text-pink-700 hover:bg-pink-200";
                                    icono.className = "fa-solid fa-heart text-lg scale-110 transition-transform";
                                    texto.innerText = "Agregado a lista de deseos";
                                } else {
                                    // MODO GRIS (Eliminado)
                                    btn.className = "w-full py-3 font-bold rounded-xl transition-all duration-200 flex justify-center items-center gap-2 bg-gray-200 text-gray-800 hover:bg-red-50 hover:text-red-600";
                                    icono.className = "fa-regular fa-heart text-lg transition-transform";
                                    texto.innerText = "Agregar a lista de deseos";
                                }
                            }
                        } else {
                            console.error("Error del servidor:", data.mensaje);
                        }
                    })
                    .catch(err => console.error('Error de conexión', err));
            }

            // Diccionario con los textos
            const textosEstrellas = {
                1: " (1) Malo",
                2: " (2) Regular",
                3: " (3) Bueno",
                4: " (4) Muy Bueno",
                5: " (5) Excelente"
            };

            // Inicializar el texto cuando carga la página
            document.addEventListener("DOMContentLoaded", () => {
                let valorInicial = document.getElementById('inputCalificacion').value;
                document.getElementById('textoCalificacion').innerText = textosEstrellas[valorInicial];
            });

            // Función que se dispara al hacer clic en una estrella
            function marcarEstrellas(valor) {
                // 1. Actualizamos el valor del input oculto (para que el form lo mande)
                document.getElementById('inputCalificacion').value = valor;

                // 2. Actualizamos el texto
                document.getElementById('textoCalificacion').innerText = textosEstrellas[valor];

                // 3. Pintamos las estrellas
                const estrellas = document.getElementById('contenedorEstrellas').children;
                for (let i = 0; i < 5; i++) {
                    if (i < valor) {
                        // Estrellas marcadas (sólidas y amarillas)
                        estrellas[i].className = "fa-solid fa-star text-yellow-400 transition-all duration-200 hover:scale-110";
                    } else {
                        // Estrellas vacías (contorno y grises)
                        estrellas[i].className = "fa-regular fa-star text-gray-300 transition-all duration-200 hover:scale-110";
                    }
                }
            }
        </script>